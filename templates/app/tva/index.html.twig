{% extends 'layout/app.html.twig' %}

{% block title %}TVA - ComptaV2{% endblock %}
{% block page_title %}TVA - Régime simplifié{% endblock %}

{% set active_page = 'tva' %}

{% block content %}

{% if success %}
<div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg mb-6 text-sm font-medium">
    Déclaration TVA enregistrée avec succès.
</div>
{% endif %}

{# Sélecteur d'année #}
<div class="flex items-center gap-3 mb-6">
    <label class="text-sm font-medium text-slate-500">Exercice</label>
    <div class="flex rounded-lg border border-slate-300 overflow-hidden">
        {% for a in annees %}
        <a href="/app/tva?annee={{ a }}"
           class="px-4 py-1.5 text-sm font-medium transition
           {{ a == annee ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-50' }}
           {{ not loop.last ? 'border-r border-slate-300' : '' }}">
            {{ a }}
        </a>
        {% endfor %}
    </div>
</div>

{% if echeances|length == 0 %}
<div class="bg-white rounded-xl shadow-sm px-8 py-16 text-center">
    <h3 class="text-lg font-medium text-slate-600 mb-1">Aucune échéance TVA pour {{ annee }}</h3>
    <p class="text-sm text-slate-400">Le calendrier TVA doit être configuré dans le portail admin.</p>
</div>
{% else %}

<div class="space-y-4">
    {% for ech in echeances %}
    {% set decl = ech.declaration %}
    {% set is_paid = decl and decl.statut == 'payee' %}
    <div class="bg-white rounded-xl shadow-sm overflow-hidden border-l-4
        {{ ech.statut_display == 'payee' ? 'border-emerald-500' : (ech.statut_display == 'en_retard' ? 'border-red-500' : 'border-amber-400') }}">

        {# En-tête cliquable #}
        <div class="px-6 py-4 flex items-center justify-between cursor-pointer hover:bg-slate-50/50 transition"
             onclick="document.getElementById('ech-{{ ech.id }}').classList.toggle('hidden'); this.querySelector('.chevron').classList.toggle('rotate-90')">
            <div>
                <h3 class="text-sm font-semibold text-slate-800">{{ ech.libelle }}</h3>
                <p class="text-xs text-slate-500 mt-0.5">Échéance : {{ ech.date_echeance|date('d/m/Y') }}</p>
            </div>
            <div class="flex items-center gap-4">
                {% if ech.statut_display == 'payee' %}
                <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-full">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    Payé {{ decl.montant_paye|number_format(0, ',', ' ') }} &euro;
                </span>
                {% elseif ech.statut_display == 'en_retard' %}
                <span class="inline-flex items-center text-xs font-medium text-red-700 bg-red-50 px-2.5 py-1 rounded-full">En retard</span>
                {% else %}
                <span class="inline-flex items-center text-xs font-medium text-amber-700 bg-amber-50 px-2.5 py-1 rounded-full">À payer</span>
                {% endif %}

                {% if ech.tva_due != 0 %}
                <span class="text-sm font-semibold tabular-nums {{ ech.tva_due > 0 ? 'text-amber-700' : 'text-indigo-700' }}">
                    {{ ech.tva_due > 0 ? ech.tva_due|round(0, 'floor')|number_format(0, ',', ' ') : ech.tva_due|round|number_format(0, ',', ' ') }} &euro;
                </span>
                {% endif %}

                <span class="chevron text-slate-400 transition-transform">&#9654;</span>
            </div>
        </div>

        {# Contenu dépliable #}
        <div id="ech-{{ ech.id }}" class="hidden border-t border-slate-100">

            {# Données calculées automatiquement #}
            <div class="px-6 py-4 bg-blue-50/50">
                <h4 class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-3">Données calculées depuis votre comptabilité</h4>
                <div class="space-y-1.5 text-sm">
                    <div class="flex justify-between">
                        <span class="text-slate-600">TVA collectée au titre {{ ech.type == 'regularisation' ? "de l'année" : 'du semestre' }}</span>
                        <span class="font-medium tabular-nums text-emerald-700">{{ ech.tva_collectee|number_format(2, ',', ' ') }} &euro;</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-600">TVA déductible au titre {{ ech.type == 'regularisation' ? "de l'année" : 'du semestre' }}</span>
                        <span class="font-medium tabular-nums text-red-600">{{ ech.tva_deductible|number_format(2, ',', ' ') }} &euro;</span>
                    </div>
                    {% if ech.type == 'regularisation' %}
                    <div class="flex justify-between">
                        <span class="text-slate-600">TVA brute due pour l'année</span>
                        <span class="font-medium tabular-nums">{{ ech.tva_due_brute|number_format(2, ',', ' ') }} &euro;</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-600">Moins : acomptes déjà payés</span>
                        <span class="font-medium tabular-nums text-emerald-600">-{{ ech.acomptes_payes|number_format(2, ',', ' ') }} &euro;</span>
                    </div>
                    {% endif %}
                    <div class="flex justify-between pt-2 border-t border-blue-200">
                        <span class="font-semibold text-slate-800">
                            {% if ech.tva_due > 0 %}
                                {{ ech.type == 'regularisation' ? 'Complément de TVA à payer' : 'TVA à payer' }}
                            {% elseif ech.tva_due < 0 %}
                                {{ ech.type == 'regularisation' ? 'Crédit de TVA (trop perçu d\'acomptes)' : 'Crédit de TVA disponible' }}
                            {% else %}
                                Situation équilibrée
                            {% endif %}
                        </span>
                        <span class="font-bold tabular-nums {{ ech.tva_due > 0 ? 'text-amber-700' : (ech.tva_due < 0 ? 'text-indigo-700' : 'text-slate-500') }}">
                            {% if ech.tva_due > 0 %}
                                {{ ech.tva_due|round(0, 'floor')|number_format(0, ',', ' ') }} &euro;
                            {% else %}
                                {{ ech.tva_due|round|number_format(0, ',', ' ') }} &euro;
                            {% endif %}
                        </span>
                    </div>

                    {% if is_paid and decl.montant_paye %}
                    {% set montant_calc = ech.tva_due > 0 ? ech.tva_due|round(0, 'floor') : ech.tva_due|round %}
                    {% set differentiel = decl.montant_paye - montant_calc %}
                    <div class="pt-2 border-t border-blue-200">
                        <div class="flex justify-between">
                            <span class="font-semibold text-slate-700">Montant effectivement payé</span>
                            <span class="font-bold tabular-nums text-emerald-700">{{ decl.montant_paye|number_format(0, ',', ' ') }} &euro;</span>
                        </div>
                        {% if differentiel != 0 %}
                        <div class="flex justify-between mt-1">
                            <span class="text-slate-600">{{ differentiel > 0 ? 'Surpaiement' : 'Sous-paiement' }}</span>
                            <span class="font-medium tabular-nums {{ differentiel > 0 ? 'text-amber-600' : 'text-red-600' }}">{{ differentiel|abs|number_format(0, ',', ' ') }} &euro;</span>
                        </div>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Détail des opérations TVA #}
            {% if ech.detail_lignes_tva|length > 0 %}
            <div class="px-6 py-4 border-t border-slate-100">
                <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-3">Détail des opérations TVA</h4>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-xs text-slate-500 uppercase tracking-wider">
                                <th class="text-left py-2 pr-3 font-medium">Date</th>
                                <th class="text-left py-2 pr-3 font-medium">Libellé</th>
                                <th class="text-left py-2 pr-3 font-medium">Compte</th>
                                <th class="text-right py-2 pr-3 font-medium">Montant HT</th>
                                <th class="text-right py-2 pr-3 font-medium">TVA</th>
                                <th class="text-left py-2 font-medium">Type</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            {% for ligne in ech.detail_lignes_tva %}
                            <tr class="hover:bg-slate-50">
                                <td class="py-2 pr-3 text-slate-600 whitespace-nowrap">{{ ligne.date|date('d/m/Y') }}</td>
                                <td class="py-2 pr-3 text-slate-800 max-w-xs truncate" title="{{ ligne.libelle }}">{{ ligne.libelle }}</td>
                                <td class="py-2 pr-3 text-slate-500 font-mono text-xs">{{ ligne.compte }}</td>
                                <td class="py-2 pr-3 text-right tabular-nums">{{ ligne.montant_ht|number_format(2, ',', ' ') }} &euro;</td>
                                <td class="py-2 pr-3 text-right tabular-nums font-semibold">{{ ligne.tva|number_format(2, ',', ' ') }} &euro;</td>
                                <td class="py-2">
                                    {% if ligne.sens_tva == 'collectee' %}
                                    <span class="inline-flex text-xs font-medium text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full">Collectée</span>
                                    {% else %}
                                    <span class="inline-flex text-xs font-medium text-red-700 bg-red-50 px-2 py-0.5 rounded-full">Déductible</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% endif %}

            {# Formulaire 3514 (si non payé) #}
            {% if not is_paid %}
            <div class="px-6 py-4 border-t border-slate-100">
                <form method="POST" action="/app/tva/payer" id="form-{{ ech.id }}">
                    <input type="hidden" name="echeance_id" value="{{ ech.id }}">
                    <input type="hidden" name="annee" value="{{ annee }}">

                    <h4 class="text-sm font-semibold text-slate-700 mb-4">Formulaire 3514 - Déclaration de TVA</h4>

                    {# Section 1 : Acompte #}
                    <div class="mb-5">
                        <div class="bg-indigo-600 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                            1 - Acquittement de l'acompte attendu, modulation ou suspension, imputation d'un crédit de TVA
                        </div>
                        <div class="border border-t-0 border-slate-200 rounded-b-lg py-3 px-4 space-y-2">
                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">01</span>
                                <span class="flex-1 text-sm text-slate-700">Montant de l'acompte attendu ou modulé</span>
                                <input type="number" step="1" name="case_01"
                                       class="w-28 border border-slate-300 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums focus:ring-2 focus:ring-indigo-500 outline-none tva-case"
                                       data-ech="{{ ech.id }}"
                                       value="{{ decl ? decl.case_01|round : ech.cases_auto.case_01 }}" placeholder="0">
                            </div>
                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">02</span>
                                <span class="flex-1 text-sm text-slate-700">Montant du crédit ou de l'excédent de TVA figurant sur la précédente déclaration CA12/CA12E</span>
                                <input type="number" step="1" name="case_02"
                                       class="w-28 border border-slate-300 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums focus:ring-2 focus:ring-indigo-500 outline-none tva-case"
                                       data-ech="{{ ech.id }}"
                                       value="{{ decl ? decl.case_02|round : 0 }}" placeholder="0">
                            </div>
                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">03</span>
                                <span class="flex-1 text-sm text-slate-700 font-medium">Montant total de la TVA à payer à la place de l'acompte de TVA</span>
                                <input type="number" step="1" name="case_03" readonly
                                       class="w-28 border border-slate-200 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums bg-slate-100 font-semibold text-slate-700 tva-result"
                                       data-ech="{{ ech.id }}"
                                       value="{{ decl ? decl.case_03|round : ech.cases_auto.case_01 }}" placeholder="0">
                            </div>
                        </div>
                    </div>

                    {# Section 2 : Crédit / Remboursement #}
                    <div class="mb-5">
                        <div class="bg-indigo-600 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                            2 - Remboursement de crédit de TVA sur investissements
                        </div>
                        <div class="border border-t-0 border-slate-200 rounded-b-lg py-3 px-4 space-y-2">
                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">05</span>
                                <span class="flex-1 text-sm text-slate-700">Montant de la TVA collectée au titre du semestre</span>
                                <input type="number" step="1" name="case_05"
                                       class="w-28 border border-slate-300 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums focus:ring-2 focus:ring-indigo-500 outline-none tva-case"
                                       data-ech="{{ ech.id }}"
                                       {{ ech.tva_due < 0 ? 'readonly' : '' }}
                                       value="{{ decl ? decl.case_05|round : ech.cases_auto.case_05 }}" placeholder="0">
                            </div>
                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">06</span>
                                <span class="flex-1 text-sm text-slate-700">Montant de la TVA déductible au titre du semestre</span>
                                <input type="number" step="1" name="case_06"
                                       class="w-28 border border-slate-300 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums focus:ring-2 focus:ring-indigo-500 outline-none tva-case"
                                       data-ech="{{ ech.id }}"
                                       {{ ech.tva_due < 0 ? 'readonly' : '' }}
                                       value="{{ decl ? decl.case_06|round : ech.cases_auto.case_06 }}" placeholder="0">
                            </div>

                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">07</span>
                                <span class="flex-1 text-sm text-slate-700 font-medium">Crédit de TVA dégagé au titre du semestre</span>
                                <input type="number" step="1" name="case_07" readonly
                                       class="w-28 border border-slate-200 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums bg-slate-100 font-semibold text-slate-700 tva-result"
                                       data-ech="{{ ech.id }}"
                                       value="{{ decl ? decl.case_07|round : ech.cases_auto.case_07 }}" placeholder="0">
                            </div>
                            <div class="flex items-center gap-3 py-1.5">
                                <span class="shrink-0 bg-indigo-600 text-white text-xs font-bold px-2.5 py-1.5 rounded text-center min-w-[40px]">08</span>
                                <span class="flex-1 text-sm text-slate-700">Remboursement de la TVA sur investissements sollicité</span>
                                <input type="number" step="1" name="case_08"
                                       class="w-28 border border-slate-300 rounded-lg pl-3 pr-5 py-2 text-sm text-right tabular-nums focus:ring-2 focus:ring-indigo-500 outline-none tva-case tva-case-08"
                                       data-ech="{{ ech.id }}"
                                       value="{{ decl ? decl.case_08|round : 0 }}" placeholder="0">
                            </div>
                        </div>
                    </div>

                    {# Résumé de la déclaration #}
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
                        <h4 class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-2">Résumé de la déclaration</h4>
                        <div class="flex justify-between items-center" id="resume-{{ ech.id }}">
                            <span class="text-sm text-slate-700" id="resume-label-{{ ech.id }}">Montant à régler</span>
                            <span class="text-lg font-bold tabular-nums" id="montant-du-{{ ech.id }}">0 &euro;</span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between">
                        <button type="submit" class="inline-flex items-center gap-2 bg-emerald-600 text-white px-5 py-2.5 rounded-lg hover:bg-emerald-700 transition font-medium text-sm shadow-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            Valider le paiement
                        </button>
                        {% if decl %}
                        <span class="text-xs text-slate-400">Dernière mise à jour : {{ decl.updated_at|date('d/m/Y H:i') }}</span>
                        {% endif %}
                    </div>
                </form>
            </div>
            {% else %}
            {# Résumé paiement #}
            <div class="px-6 py-3 border-t border-slate-100 text-sm text-slate-500 flex items-center justify-between">
                <div class="flex items-center gap-1">
                    <span>Payé le</span>
                    <form method="POST" action="/app/tva/date-paiement" class="inline-flex items-center gap-1">
                        <input type="hidden" name="echeance_id" value="{{ ech.id }}">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="date" name="date_paiement" value="{{ decl.date_paiement }}"
                               class="border border-transparent hover:border-slate-300 focus:border-indigo-500 rounded px-1.5 py-0.5 text-sm text-slate-600 bg-transparent focus:bg-white outline-none transition"
                               onchange="this.form.submit()">
                    </form>
                    <span>&middot; {{ decl.montant_paye|number_format(2, ',', ' ') }} &euro;</span>
                </div>
                <span class="text-xs text-slate-400">
                    Cases : 01={{ decl.case_01|round }}, 02={{ decl.case_02|round }}, 03={{ decl.case_03|round }}
                    {% if decl.case_07 > 0 %}, 05={{ decl.case_05|round }}, 06={{ decl.case_06|round }}, 07={{ decl.case_07|round }}{% endif %}
                    {% if decl.case_08 > 0 %}, 08={{ decl.case_08|round }}{% endif %}
                </span>
            </div>
            {% endif %}
        </div>
    </div>
    {% endfor %}
</div>

{% endif %}

{% endblock %}

{% block scripts %}
<script src="/js/tva.js"></script>
{% endblock %}
