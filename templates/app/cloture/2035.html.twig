{% extends 'app/cloture/_layout.html.twig' %}

{% block tab_content %}

<form method="POST" action="/app/cloture/save">
    <input type="hidden" name="tab" value="2035">
    <input type="hidden" name="annee" value="{{ annee }}">

    {# En-tête officiel #}
    <div class="bg-white rounded-xl shadow-sm overflow-hidden mb-6">
        <div class="px-6 py-5 flex items-start justify-between border-b border-slate-200">
            <div class="flex items-start gap-4">
                <div class="text-xs text-slate-500 leading-tight font-semibold">
                    REPUBLIQUE<br>FRANCAISE
                </div>
                <div class="text-sm text-slate-600">
                    <p class="font-semibold">DIRECTION GENERALE DES FINANCES PUBLIQUES</p>
                    <p class="mt-1 text-base font-bold text-slate-800">Benefices non commerciaux et assimiles</p>
                    <p class="text-slate-500">Regime de la declaration controlee</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-lg font-bold text-slate-800">N. 2035</p>
                <p class="text-xs text-slate-500">Declaration au {{ annee + 1 }}</p>
            </div>
        </div>

        <div class="p-6 space-y-6">

            {# Section : Identification #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Identification du declarant
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg p-4 space-y-3">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Nom / Raison sociale</label>
                            <input type="text" name="fields[raison_sociale]" value="{{ data.raison_sociale ?? entreprise_data.raison_sociale }}" readonly
                                   class="w-full bg-slate-50 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">N. SIRET</label>
                            <input type="text" name="fields[siret]" value="{{ data.siret ?? entreprise_data.siret }}" readonly
                                   class="w-full bg-slate-50 text-sm font-mono">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-1">Adresse du declarant</label>
                        <input type="text" name="fields[adresse]" value="{{ data.adresse ?? (entreprise_data.adresse ~ ' ' ~ entreprise_data.code_postal ~ ' ' ~ entreprise_data.ville)|trim }}" readonly
                               class="w-full bg-slate-50 text-sm">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Telephone</label>
                            <input type="text" name="fields[telephone]" value="{{ data.telephone ?? entreprise_data.telephone }}" readonly
                                   class="w-full bg-slate-50 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Adresse electronique</label>
                            <input type="text" name="fields[email]" value="{{ data.email ?? entreprise_data.email }}" readonly
                                   class="w-full bg-slate-50 text-sm">
                        </div>
                    </div>
                </div>
            </div>

            {# Section : Periode d'imposition #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Periode d'imposition
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg p-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Du</label>
                            <input type="text" name="fields[periode_du]" value="{{ data.periode_du ?? '01/01/' ~ annee }}" readonly
                                   class="w-full bg-slate-50 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Au</label>
                            <input type="text" name="fields[periode_au]" value="{{ data.periode_au ?? '31/12/' ~ annee }}" readonly
                                   class="w-full bg-slate-50 text-sm">
                        </div>
                    </div>
                </div>
            </div>

            {# Section : Activite exercee #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Activite exercee
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg p-4 space-y-3">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Nature de l'activite</label>
                            <input type="text" name="fields[nature_activite]" value="{{ data.nature_activite ?? '' }}"
                                   class="w-full text-sm" placeholder="Ex : Conseil en informatique">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Code NAF</label>
                            <input type="text" name="fields[code_naf]" value="{{ data.code_naf ?? '' }}"
                                   class="w-full text-sm" placeholder="Ex : 6202A">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-1">Lieu d'exercice de l'activite (si different du domicile)</label>
                        <input type="text" name="fields[lieu_exercice]" value="{{ data.lieu_exercice ?? '' }}"
                               class="w-full text-sm">
                    </div>
                </div>
            </div>

            {# Section : Regime d'imposition et options #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Regime d'imposition et options
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg p-4 space-y-2">
                    <label class="flex items-center gap-2 text-sm text-slate-700">
                        <input type="checkbox" name="fields[declaration_controlee]" value="1"
                               {{ data.declaration_controlee ?? '1' ? 'checked' : '' }}
                               class="rounded border-slate-300 text-purple-600 focus:ring-purple-500">
                        Declaration controlee
                    </label>
                    <label class="flex items-center gap-2 text-sm text-slate-700">
                        <input type="checkbox" name="fields[option_creances_dettes]" value="1"
                               {{ data.option_creances_dettes is defined and data.option_creances_dettes ? 'checked' : '' }}
                               class="rounded border-slate-300 text-purple-600 focus:ring-purple-500">
                        Option pour la comptabilite creances-dettes (engagement)
                    </label>
                </div>
            </div>

            {# Section : OGA #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Organisme de gestion agree (OGA)
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg p-4 space-y-3">
                    <label class="flex items-center gap-2 text-sm text-slate-700">
                        <input type="checkbox" name="fields[adherent_oga]" value="1"
                               {{ data.adherent_oga is defined and data.adherent_oga ? 'checked' : '' }}
                               class="rounded border-slate-300 text-purple-600 focus:ring-purple-500">
                        Adherent d'un organisme de gestion agree (OGA) ou d'un viseur fiscal
                    </label>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Nom de l'OGA</label>
                            <input type="text" name="fields[oga_nom]" value="{{ data.oga_nom ?? '' }}"
                                   class="w-full text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">N. d'agrement</label>
                            <input type="text" name="fields[oga_agrement]" value="{{ data.oga_agrement ?? '' }}"
                                   class="w-full text-sm">
                        </div>
                    </div>
                </div>
            </div>

            {# Section 1 : Recapitulation des elements d'imposition #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    1. Recapitulation des elements d'imposition
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg py-2 px-4 space-y-1">
                    {% set lines_recap = [
                        {code: 'CR', label: "Benefice (report de la ligne 46 page 2035-A)"},
                        {code: 'CS', label: "Deficit (report de la ligne 47 page 2035-A)"},
                        {code: 'CT', label: "Plus-values a court terme"},
                        {code: 'CU', label: "Moins-values a court terme"},
                        {code: 'CV', label: "Plus-values nettes a long terme imposables a 12,80 %"},
                        {code: 'CW', label: "Plus-values a long terme exonerees"},
                        {code: 'CX', label: "Moins-values nettes a long terme"},
                    ] %}
                    {% for line in lines_recap %}
                    <div class="flex items-center gap-3 py-1.5">
                        <span class="shrink-0 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded text-center min-w-[36px]">{{ line.code }}</span>
                        <span class="flex-1 text-sm text-slate-700">{{ line.label }}</span>
                        <input type="text" name="fields[{{ line.code }}]" value="{{ data[line.code] ?? '' }}"
                               class="w-28 text-sm text-right tabular-nums" placeholder="0">
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Section 2 : Resultat fiscal #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    2. Resultat fiscal
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg py-2 px-4 space-y-1">
                    {% set lines_fiscal = [
                        {code: 'CY', label: "Benefice ou deficit (CR ou CS)"},
                        {code: 'CZ', label: "Reintegrations (detail sur 2035-SUITE)"},
                        {code: 'DA', label: "Deductions (detail sur 2035-SUITE)"},
                        {code: 'DB', label: "Resultat fiscal : benefice"},
                        {code: 'DC', label: "Resultat fiscal : deficit"},
                    ] %}
                    {% for line in lines_fiscal %}
                    <div class="flex items-center gap-3 py-1.5">
                        <span class="shrink-0 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded text-center min-w-[36px]">{{ line.code }}</span>
                        <span class="flex-1 text-sm text-slate-700">{{ line.label }}</span>
                        <input type="text" name="fields[{{ line.code }}]" value="{{ data[line.code] ?? '' }}"
                               class="w-28 text-sm text-right tabular-nums" placeholder="0">
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Section 3 : Divers #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    3. Divers
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg py-2 px-4 space-y-1">
                    {% set lines_divers = [
                        {code: 'DD', label: "TVA collectee (si assujetti)"},
                        {code: 'DE', label: "Cotisation sur la valeur ajoutee des entreprises (CVAE)"},
                        {code: 'DF', label: "Nombre de salaries"},
                    ] %}
                    {% for line in lines_divers %}
                    <div class="flex items-center gap-3 py-1.5">
                        <span class="shrink-0 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded text-center min-w-[36px]">{{ line.code }}</span>
                        <span class="flex-1 text-sm text-slate-700">{{ line.label }}</span>
                        <input type="text" name="fields[{{ line.code }}]" value="{{ data[line.code] ?? '' }}"
                               class="w-28 text-sm text-right tabular-nums" placeholder="0">
                    </div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>

    <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Enregistrer
    </button>
</form>

{% endblock %}
