                <td class="px-3 py-1 text-xs text-slate-600"><span class="text-slate-400">(3)</span> Dont comptes courants d'associés débiteurs <span class="text-slate-300 text-[10px]">199</span></td>
                <td class="px-0.5">{{ _self.inp('199', data, computed) }}</td>
            </tr>
            <tr class="border-t border-slate-100 hover:bg-slate-50/50">
                <td class="px-3 py-1 text-xs text-slate-600"><span class="text-slate-400">(4)</span> Dont dettes à plus d'un an <span class="text-slate-300 text-[10px]">195</span></td>
                <td class="px-0.5">{{ _self.inp('195', data, {}) }}</td>
            </tr>
            <tr class="border-t border-slate-100 hover:bg-slate-50/50">
                <td class="px-3 py-1 text-xs text-slate-600"><span class="text-slate-400">(5)</span> Coût de revient des immo. acquises ou créées au cours de l'exercice <span class="text-slate-300 text-[10px]">182</span></td>
                <td class="px-0.5">{{ _self.inp('182', data, {}) }}</td>
            </tr>
            <tr class="border-t border-slate-100 hover:bg-slate-50/50">
                <td class="px-3 py-1 text-xs text-slate-600">Prix de cession hors TVA des immo. cédées au cours de l'exercice <span class="text-slate-300 text-[10px]">184</span></td>
                <td class="px-0.5">{{ _self.inp('184', data, {}) }}</td>
            </tr>
        </tbody>
    </table>
    </div>
</div>

{# Boutons d'action #}
<div class="flex justify-end gap-3 mt-4">
    <a href="/app/cloture/bilan?annee={{ annee }}&reset=1" id="btnReset"
       class="px-5 py-2.5 border border-slate-300 text-sm font-medium rounded-lg transition shadow-sm
       {% if data|length > 0 %}text-amber-700 border-amber-300 bg-amber-50 hover:bg-amber-100 cursor-pointer{% else %}text-slate-400 pointer-events-none{% endif %}">
        Réinitialiser
    </a>
    <button type="button" onclick="window._bilanEdit()" id="btnEdit"
            class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition shadow-sm">
        Modifier
    </button>
    <button type="submit" id="btnSave"
            class="hidden px-5 py-2.5 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition shadow-sm">
        Enregistrer
    </button>
</div>

</form>

<script src="/js/bilan.js"></script>

{% endblock %}
