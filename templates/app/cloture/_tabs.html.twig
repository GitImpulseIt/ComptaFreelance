<div class="border-b border-slate-200 mb-6 overflow-x-auto">
    <nav class="flex gap-0.5 min-w-max">
        {% for tab in tabs %}
        <a href="/app/cloture/{{ tab.slug }}?annee={{ annee }}"
           class="px-3 py-2.5 text-xs font-medium rounded-t-lg transition whitespace-nowrap
           {% if active_tab == tab.slug %}bg-white border border-b-white border-slate-200 -mb-px text-indigo-600{% else %}text-slate-500 hover:text-slate-700 hover:bg-slate-50{% endif %}">
            {{ tab.label }}
        </a>
        {% endfor %}
    </nav>
</div>
