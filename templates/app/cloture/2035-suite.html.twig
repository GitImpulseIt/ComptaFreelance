{% extends 'app/cloture/_layout.html.twig' %}

{% block tab_content %}

<form method="POST" action="/app/cloture/save">
    <input type="hidden" name="tab" value="2035-suite">
    <input type="hidden" name="annee" value="{{ annee }}">

    <div class="bg-white rounded-xl shadow-sm overflow-hidden mb-6">

        {# En-tete officiel #}
        <div class="px-6 py-5 flex items-start justify-between border-b border-slate-200">
            <div class="flex items-start gap-4">
                <div class="text-xs text-slate-500 leading-tight font-semibold">
                    REPUBLIQUE<br>FRANCAISE
                </div>
                <div class="text-sm text-slate-600">
                    <p class="font-semibold">DIRECTION GENERALE DES FINANCES PUBLIQUES</p>
                    <p class="mt-1 text-base font-bold text-slate-800">Benefices non commerciaux - Suite</p>
                    <p class="text-slate-500">Annexe a la declaration n. 2035 - Exercice du 01/01/{{ annee }} au 31/12/{{ annee }}</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-lg font-bold text-slate-800">N. 2035-SUITE</p>
            </div>
        </div>

        <div class="p-6 space-y-6">

            {# Tableau des immobilisations et amortissements #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Tableau des immobilisations et amortissements
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg overflow-x-auto">
                    <table class="w-full text-xs">
                        <thead>
                            <tr class="bg-purple-50 text-purple-800">
                                <th class="text-left py-2 px-3 font-semibold">Designation</th>
                                <th class="text-center py-2 px-2 font-semibold">Date</th>
                                <th class="text-center py-2 px-2 font-semibold">Compte</th>
                                <th class="text-right py-2 px-2 font-semibold">Valeur d'origine</th>
                                <th class="text-center py-2 px-2 font-semibold">Duree</th>
                                <th class="text-right py-2 px-2 font-semibold">Amort. anterieur</th>
                                <th class="text-right py-2 px-2 font-semibold">Dotation {{ annee }}</th>
                                <th class="text-right py-2 px-2 font-semibold">Amort. total</th>
                                <th class="text-right py-2 px-3 font-semibold">VNC</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            {% set total_valeur = 0 %}
                            {% set total_anterieur = 0 %}
                            {% set total_dotation = 0 %}
                            {% set total_cumul = 0 %}
                            {% set total_vnc = 0 %}
                            {% for immo in immobilisations %}
                            {% set total_valeur = total_valeur + immo.valeur %}
                            {% set total_anterieur = total_anterieur + immo.cumul_anterieur %}
                            {% set total_dotation = total_dotation + immo.dotation %}
                            {% set total_cumul = total_cumul + immo.cumul_total %}
                            {% set total_vnc = total_vnc + immo.vnc %}
                            <tr class="hover:bg-slate-50">
                                <td class="py-1.5 px-3 text-slate-800">{{ immo.designation }}</td>
                                <td class="py-1.5 px-2 text-center text-slate-600">{{ immo.date_acquisition|date('d/m/Y') }}</td>
                                <td class="py-1.5 px-2 text-center text-slate-500 font-mono">{{ immo.compte }}</td>
                                <td class="py-1.5 px-2 text-right tabular-nums">{{ immo.valeur|number_format(2, ',', ' ') }}</td>
                                <td class="py-1.5 px-2 text-center text-slate-600">{{ immo.duree }} ans {{ immo.type == 'degressif' ? 'D' : 'L' }}</td>
                                <td class="py-1.5 px-2 text-right tabular-nums">{{ immo.cumul_anterieur|number_format(2, ',', ' ') }}</td>
                                <td class="py-1.5 px-2 text-right tabular-nums font-semibold">{{ immo.dotation|number_format(2, ',', ' ') }}</td>
                                <td class="py-1.5 px-2 text-right tabular-nums">{{ immo.cumul_total|number_format(2, ',', ' ') }}</td>
                                <td class="py-1.5 px-3 text-right tabular-nums">{{ immo.vnc|number_format(2, ',', ' ') }}</td>
                            </tr>
                            {% endfor %}
                            {% if immobilisations|length == 0 %}
                            <tr>
                                <td colspan="9" class="py-4 px-3 text-center text-slate-400">Aucune immobilisation</td>
                            </tr>
                            {% endif %}
                        </tbody>
                        {% if immobilisations|length > 0 %}
                        <tfoot>
                            <tr class="bg-purple-50 font-semibold text-purple-900">
                                <td class="py-2 px-3" colspan="3">TOTAUX</td>
                                <td class="py-2 px-2 text-right tabular-nums">{{ total_valeur|number_format(2, ',', ' ') }}</td>
                                <td class="py-2 px-2"></td>
                                <td class="py-2 px-2 text-right tabular-nums">{{ total_anterieur|number_format(2, ',', ' ') }}</td>
                                <td class="py-2 px-2 text-right tabular-nums">{{ total_dotation|number_format(2, ',', ' ') }}</td>
                                <td class="py-2 px-2 text-right tabular-nums">{{ total_cumul|number_format(2, ',', ' ') }}</td>
                                <td class="py-2 px-3 text-right tabular-nums">{{ total_vnc|number_format(2, ',', ' ') }}</td>
                            </tr>
                        </tfoot>
                        {% endif %}
                    </table>
                </div>
            </div>

            {# Reintegrations #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Reintegrations
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg py-2 px-4 space-y-1">
                    {% set lines_reint = [
                        {code: 'CJ', label: "Part privee des depenses mixtes (quote-part non professionnelle)"},
                        {code: 'CK', label: "Avantages en nature (exploitant)"},
                        {code: 'CL', label: "Divers a reintegrer (detailler sur note jointe)"},
                        {code: 'CM', label: "TOTAL DES REINTEGRATIONS"},
                    ] %}
                    {% for line in lines_reint %}
                    <div class="flex items-center gap-3 py-1.5 {{ line.code == 'CM' ? 'border-t border-slate-200 pt-2 mt-1' : '' }}">
                        <span class="shrink-0 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded text-center min-w-[36px]">{{ line.code }}</span>
                        <span class="flex-1 text-sm text-slate-700 {{ line.code == 'CM' ? 'font-semibold' : '' }}">{{ line.label }}</span>
                        <input type="text" name="fields[{{ line.code }}]" value="{{ data[line.code] ?? '' }}"
                               class="w-28 text-sm text-right tabular-nums {{ line.code == 'CM' ? 'bg-slate-50 font-semibold' : '' }}" placeholder="0">
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Deductions #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Deductions
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg py-2 px-4 space-y-1">
                    {% set lines_deduc = [
                        {code: 'CN', label: "Abondement dans le cadre de l'epargne salariale"},
                        {code: 'CO', label: "Plus-values a court terme dont l'imposition est differee"},
                        {code: 'CP', label: "Benefices non imposables en France (conventions internationales)"},
                        {code: 'CQ', label: "Divers a deduire (detailler sur note jointe)"},
                        {code: 'CS', label: "TOTAL DES DEDUCTIONS"},
                    ] %}
                    {% for line in lines_deduc %}
                    <div class="flex items-center gap-3 py-1.5 {{ line.code == 'CS' ? 'border-t border-slate-200 pt-2 mt-1' : '' }}">
                        <span class="shrink-0 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded text-center min-w-[36px]">{{ line.code }}</span>
                        <span class="flex-1 text-sm text-slate-700 {{ line.code == 'CS' ? 'font-semibold' : '' }}">{{ line.label }}</span>
                        <input type="text" name="fields[{{ line.code }}]" value="{{ data[line.code] ?? '' }}"
                               class="w-28 text-sm text-right tabular-nums {{ line.code == 'CS' ? 'bg-slate-50 font-semibold' : '' }}" placeholder="0">
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Exoneration et abattements #}
            <div>
                <div class="bg-purple-700 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-t-lg">
                    Exonerations et abattements
                </div>
                <div class="border border-t-0 border-slate-200 rounded-b-lg py-2 px-4 space-y-1">
                    {% set lines_exo = [
                        {code: 'CT', label: "Exoneration zone franche urbaine (ZFU)"},
                        {code: 'CU', label: "Exoneration zone de revitalisation rurale (ZRR)"},
                        {code: 'CV', label: "Exoneration jeune entreprise innovante (JEI)"},
                        {code: 'CW', label: "Abattement groupements forestiers / fonciers"},
                        {code: 'CX', label: "Autres exonerations (preciser)"},
                    ] %}
                    {% for line in lines_exo %}
                    <div class="flex items-center gap-3 py-1.5">
                        <span class="shrink-0 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded text-center min-w-[36px]">{{ line.code }}</span>
                        <span class="flex-1 text-sm text-slate-700">{{ line.label }}</span>
                        <input type="text" name="fields[{{ line.code }}]" value="{{ data[line.code] ?? '' }}"
                               class="w-28 text-sm text-right tabular-nums" placeholder="0">
                    </div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>

    <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Enregistrer
    </button>
</form>

{% endblock %}
