{% extends 'layout/app.html.twig' %}

{% block title %}Clôture d'exercice {{ annee }} - ComptaV2{% endblock %}
{% block page_title %}Clôture d'exercice{% endblock %}

{% set active_page = 'cloture' %}

{% block content %}

{# Sélecteur d'année #}
<div class="flex items-center gap-3 mb-4">
    <label class="text-sm font-medium text-slate-500">Exercice</label>
    <div class="flex rounded-lg border border-slate-300 overflow-hidden">
        {% for a in annees %}
        <a href="/app/cloture/{{ active_tab }}?annee={{ a }}"
           class="px-4 py-1.5 text-sm font-medium transition
           {{ a == annee ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-50' }}
           {{ not loop.last ? 'border-r border-slate-300' : '' }}">
            {{ a }}
        </a>
        {% endfor %}
    </div>
</div>

{% if success is defined and success %}
<div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg mb-4 text-sm font-medium">
    Déclaration enregistrée.
</div>
{% endif %}

{# Onglets #}
{% include 'app/cloture/_tabs.html.twig' %}

{# Contenu de l'onglet #}
{% block tab_content %}{% endblock %}

{% endblock %}
