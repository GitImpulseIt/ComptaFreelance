{% extends 'app/cloture/_layout.html.twig' %}

{% block tab_content %}

{# ── Macros ── #}
{% macro inp(name, data, comp, ck) %}
{% set actual_ck = ck|default(name) %}
{% set sv = data[name]|default('') %}
{% set cv = comp[actual_ck]|default('') %}
<input type="text" inputmode="numeric" name="fields[{{ name }}]" id="c{{ name }}"
       value="{{ sv != '' ? sv : cv }}"
       class="w-full text-right tabular-nums text-xs px-2 py-1 border-0 bg-transparent focus:bg-indigo-50 focus:outline-none"
       autocomplete="off">
{% endmacro %}

{% macro ro(name) %}
<input type="text" name="fields[{{ name }}]" id="c{{ name }}"
       class="w-full text-right tabular-nums text-xs px-2 py-1 border-0 bg-transparent text-slate-600 font-semibold"
       readonly tabindex="-1">
{% endmacro %}

<form method="post" action="/app/cloture/save" id="crForm">
<input type="hidden" name="tab" value="compte-resultat">
<input type="hidden" name="annee" value="{{ annee }}">

