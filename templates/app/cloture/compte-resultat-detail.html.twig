{% extends 'app/cloture/_layout.html.twig' %}

{% block tab_content %}

<div class="flex items-center justify-between mb-6">
    <h3 class="text-lg font-bold text-slate-800">Détail du compte de résultat — Exercice {{ annee }}</h3>
    <a href="/app/cloture/compte-resultat?annee={{ annee }}"
       class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-indigo-600 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Retour au compte de résultat
    </a>
</div>

{% if sections|length == 0 %}
<div class="bg-white rounded-xl shadow-sm px-8 py-16 text-center">
    <h3 class="text-lg font-medium text-slate-600 mb-1">Aucune opération</h3>
    <p class="text-sm text-slate-400">Aucune case du compte de résultat n'a de valeur calculée pour cet exercice.</p>
</div>
{% else %}

{% for section in sections %}
<div class="bg-white rounded-xl shadow-sm overflow-hidden mb-4">
    <div class="px-4 py-2.5 bg-slate-800 text-white flex items-center justify-between">
        <span class="font-medium text-sm">Case {{ section.case }} — {{ section.label }}</span>
        <span class="text-sm tabular-nums font-bold">{{ section.total|number_format(2, ',', ' ') }} &euro;</span>
    </div>
    <div class="overflow-x-auto">
    <table class="compta-table w-full border-collapse">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left px-3 py-2 text-[11px] font-semibold text-slate-500 uppercase w-[12%]">Date</th>
                <th class="text-left px-3 py-2 text-[11px] font-semibold text-slate-500 uppercase">Libellé</th>
                <th class="text-left px-3 py-2 text-[11px] font-semibold text-slate-500 uppercase w-[12%]">Compte</th>
                <th class="text-right px-3 py-2 text-[11px] font-semibold text-slate-500 uppercase w-[15%]">Montant</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for ligne in section.lignes %}
            <tr class="hover:bg-slate-50/50">
                <td class="px-3 py-1.5 text-xs text-slate-600 tabular-nums">{{ ligne.date|date('d/m/Y') }}</td>
                <td class="px-3 py-1.5 text-xs text-slate-800">{{ ligne.libelle }}</td>
                <td class="px-3 py-1.5 text-xs text-slate-500 font-mono">{{ ligne.compte }}</td>
                <td class="px-3 py-1.5 text-xs text-right tabular-nums font-medium">{{ ligne.montant|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>
{% endfor %}

{% endif %}

{% endblock %}
