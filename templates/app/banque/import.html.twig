{% extends 'layout/app.html.twig' %}

{% block title %}Import bancaire - ComptaV2{% endblock %}
{% block page_title %}Importer un relevé bancaire{% endblock %}

{% block content %}
<div class="max-w-2xl">
    <form method="POST" action="/app/banque/import" enctype="multipart/form-data" class="space-y-6">
        <div>
            <label for="compte" class="block text-sm font-medium text-gray-700">Compte bancaire</label>
            <select id="compte" name="compte_id" required
                    class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm">
                {# Options des comptes #}
            </select>
        </div>
        <div>
            <label for="format" class="block text-sm font-medium text-gray-700">Format du fichier</label>
            <select id="format" name="format" required
                    class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm">
                <option value="csv">CSV</option>
                <option value="ofx">OFX</option>
                <option value="qif">QIF</option>
            </select>
        </div>
        <div>
            <label for="fichier" class="block text-sm font-medium text-gray-700">Fichier</label>
            <input type="file" id="fichier" name="fichier" required accept=".csv,.ofx,.qif"
                   class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
        </div>
        <button type="submit"
                class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">
            Importer
        </button>
    </form>
</div>
{% endblock %}
