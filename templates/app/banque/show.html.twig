{% extends 'layout/app.html.twig' %}

{% block title %}Qualification - ComptaV2{% endblock %}
{% block page_title %}Qualification de l'opération{% endblock %}

{% set active_page = 'banque' %}

{% block head %}
<style>
    .compta-input-row input, .compta-input-row select {
        border: 1px solid #cbd5e1;
        border-radius: 0.5rem;
        padding: 0.375rem 0.5rem;
        font-size: 0.875rem;
        outline: none;
    }
    .compta-input-row input:focus, .compta-input-row select:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }
    .tva-source { background-color: #fef3c7 !important; }
</style>
{% endblock %}

{% block content %}

{# Navigation retour #}
<div class="flex items-center gap-3 mb-6">
    <a href="/app/banque" class="text-slate-400 hover:text-slate-600 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h3 class="text-lg font-semibold text-slate-800">Retour aux opérations</h3>
</div>

{# Message succès #}
{% if success %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">
    Lignes comptables enregistrées avec succès.
</div>
{% endif %}

{# En-tête de la transaction #}
<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
    <div class="flex items-start justify-between">
        <div>
            <p class="text-sm text-slate-500">{{ transaction.date|date('d/m/Y') }} &middot; {{ transaction.compte_nom }}</p>
            <h2 class="text-xl font-bold text-slate-800 mt-1">{{ transaction.libelle }}</h2>
        </div>
        <div class="text-right">
            <p class="text-2xl font-bold {{ transaction.type == 'credit' ? 'text-emerald-600' : 'text-red-600' }}">
                {{ transaction.type == 'credit' ? '+' : '-' }}{{ transaction.montant|number_format(2, ',', ' ') }} &euro;
            </p>
            <span class="inline-flex items-center gap-1 text-xs font-medium mt-1 px-2 py-0.5 rounded-full
                {{ transaction.type == 'credit' ? 'text-emerald-700 bg-emerald-50' : 'text-red-700 bg-red-50' }}">
                {{ transaction.type == 'credit' ? 'Crédit' : 'Débit' }}
            </span>
        </div>
    </div>
</div>

{# Liens documents #}
<div class="bg-white rounded-xl shadow-sm p-6 mb-6" id="liens-section" data-transaction-id="{{ transaction.id }}">
    <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-slate-700">Liens documents</h3>
        <button type="button" id="add-lien" class="inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter
        </button>
    </div>
    <ul id="liens-list" class="space-y-1.5">
        {% for lien in liens %}
        <li class="lien-item group flex items-center gap-2" data-id="{{ lien.id }}">
            <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            <a href="{{ lien.url }}" target="_blank" rel="noopener" class="text-sm text-indigo-600 hover:text-indigo-800 truncate max-w-md" title="{{ lien.url }}">{{ lien.url }}</a>
            <button type="button" class="lien-remove opacity-0 group-hover:opacity-100 text-slate-400 hover:text-red-500 transition shrink-0" data-id="{{ lien.id }}" title="Supprimer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
        </li>
        {% endfor %}
    </ul>
    {% if liens|length == 0 %}
    <p id="liens-empty" class="text-sm text-slate-400">Aucun document lié.</p>
    {% endif %}
</div>

{# Formulaire de qualification comptable #}
<form method="POST" action="/app/banque/{{ transaction.id }}" id="compta-form">
    <div class="bg-white rounded-xl shadow-sm overflow-hidden mb-4">
        <table class="w-full" id="compta-table">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider w-64">Compte</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider w-32">Montant HT</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider w-24">Type</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider w-28">TVA</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider w-32">Montant TTC</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider w-28">Taux TVA (%)</th>
                    <th class="px-4 py-3 w-16"></th>
                </tr>
            </thead>
            <tbody id="compta-tbody" class="divide-y divide-slate-100">
                {% for line in lignes %}
                <tr class="compta-row group hover:bg-slate-50/80 transition" {% if line.is_main is defined and line.is_main %}data-main="1"{% endif %}>
                    <td class="px-4 py-3 text-sm text-slate-700">
                        <div class="font-mono">{{ line.compte }}</div>
                        {% if compte_labels[line.compte] is defined and compte_labels[line.compte] %}
                        <div class="text-xs text-slate-500 truncate" title="{{ compte_labels[line.compte] }}">{{ compte_labels[line.compte] }}</div>
                        {% endif %}
                        <input type="hidden" name="compte[]" value="{{ line.compte }}">
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700">{{ line.montant_ht|replace({'.': ','}) }}<input type="hidden" name="montant_ht[]" value="{{ line.montant_ht }}"></td>
                    <td class="px-4 py-3 text-sm text-slate-700">{{ line.type == 'DBT' ? 'Débit' : 'Crédit' }}<input type="hidden" name="type[]" value="{{ line.type }}"></td>
                    <td class="px-4 py-3 text-sm text-slate-700">{% if line.tva and line.tva != '0' and line.tva != 0 %}{{ line.tva|replace({'.': ','}) }}{% endif %}<input type="hidden" name="tva[]" value="{{ line.tva }}"></td>
                    <td class="px-4 py-3 text-sm text-slate-700">{% set ht = line.montant_ht|round(2) %}{% set t = line.tva|round(2) %}{% if t != 0 %}{{ (ht + t)|number_format(2, ',', ' ') }}{% endif %}</td>
                    <td class="px-4 py-3 text-sm text-slate-700">{% if t != 0 and ht > 0 %}{{ ((t / ht) * 100)|legal_vat_rate|number_format(2, ',', ' ') }}%{% endif %}</td>
                    <td class="px-4 py-3 text-center">
                        {% if not (line.is_main is defined and line.is_main) %}
                        <span class="compta-remove text-slate-300 hover:text-red-500 cursor-pointer transition opacity-0 group-hover:opacity-100" title="Supprimer">
                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        </span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="flex items-center gap-4">
        <button type="button" id="add-line" class="inline-flex items-center gap-2 border border-slate-300 text-slate-600 px-4 py-2 rounded-lg hover:bg-slate-50 transition text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter une ligne
        </button>
        <button type="button" id="propose-ia" data-transaction-id="{{ transaction.id }}"
                class="inline-flex items-center gap-2 border border-indigo-300 bg-indigo-50 text-indigo-700 px-4 py-2 rounded-lg hover:bg-indigo-100 transition text-sm font-medium">
            <svg id="propose-ia-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            <span id="propose-ia-label">Proposer avec l'IA</span>
        </button>
        <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm font-medium shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Valider
        </button>
        {% if transaction.type == 'debit' %}
        <a href="/app/immobilisations/create?designation={{ transaction.libelle|url_encode }}&date_acquisition={{ transaction.date|date('Y-m-d') }}&valeur={{ transaction.montant }}&retour={{ transaction.id }}"
           class="inline-flex items-center gap-2 border border-slate-300 text-slate-600 px-4 py-2 rounded-lg hover:bg-slate-50 transition text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            Créer une immobilisation
        </a>
        {% endif %}
        <span id="sum-warning" class="text-sm text-red-600 font-medium hidden">
            Les débits et crédits ne sont pas équilibrés
        </span>
    </div>

    {# Explication de la proposition IA — affichée sous les boutons, en emphase #}
    <div id="propose-ia-explanation" class="hidden mt-4 p-4 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-violet-50 shadow-sm">
        <div class="flex items-start gap-3">
            <div class="shrink-0 w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
                <div class="text-xs font-semibold text-indigo-600 uppercase tracking-wider mb-1">Proposition de l'IA</div>
                <p id="propose-ia-explanation-text" class="text-sm text-slate-700 leading-relaxed"></p>
            </div>
        </div>
    </div>
</form>

{% endblock %}

{% block scripts %}
<script>
window.PLAN_COMPTABLE = {{ plan_comptable|json_encode|raw }};
window.PLAN_MODE = {{ plan_mode|json_encode|raw }};
</script>
<script src="/js/transaction.js"></script>
{% endblock %}
