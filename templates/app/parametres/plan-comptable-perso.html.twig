{% extends 'layout/app.html.twig' %}

{% block title %}{{ compte ? 'Modifier' : 'Nouveau' }} compte personnalisé - Paramètres - ComptaV2{% endblock %}
{% block page_title %}{{ compte ? 'Modifier le compte ' ~ compte.numero : 'Nouveau compte personnalisé' }}{% endblock %}

{% set active_page = 'parametres' %}

{% block content %}
{% include 'app/parametres/_tabs.html.twig' %}

<div class="flex items-center gap-3 mb-6">
    <a href="/app/parametres/plan-comptable" class="text-slate-400 hover:text-slate-600 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h3 class="text-lg font-semibold text-slate-800">Retour au plan comptable</h3>
</div>

{% if session.error is defined %}
<div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">{{ session.error }}</div>
{% endif %}

<form method="POST"
      action="{{ compte ? '/app/parametres/plan-comptable/perso/' ~ compte.numero : '/app/parametres/plan-comptable/perso' }}"
      class="bg-white rounded-xl shadow-sm p-6 max-w-xl">
    <div class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Numéro</label>
            {% if compte %}
            <input type="text" value="{{ compte.numero }}" disabled
                   class="w-full border border-slate-200 bg-slate-50 rounded-lg px-3 py-2 text-sm font-mono text-slate-500">
            <p class="mt-1 text-xs text-slate-500">Le numéro ne peut pas être modifié.</p>
            {% else %}
            <input type="text" name="numero" required pattern="\d{2,10}" inputmode="numeric"
                   placeholder="ex. 606010"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none font-mono">
            <p class="mt-1 text-xs text-slate-500">2 à 10 chiffres. Doit être unique dans vos comptes personnalisés.</p>
            {% endif %}
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Libellé</label>
            <input type="text" name="libelle" required maxlength="255"
                   value="{{ compte.libelle ?? '' }}"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Sens</label>
            <div class="flex gap-2">
                <label class="flex-1 flex items-center justify-center gap-2 border border-slate-300 rounded-lg px-3 py-2 text-sm cursor-pointer hover:bg-slate-50 has-[:checked]:bg-red-50 has-[:checked]:border-red-400">
                    <input type="radio" name="sens" value="D" required {{ (compte.sens ?? '') == 'D' ? 'checked' : '' }} class="sr-only">
                    Débit
                </label>
                <label class="flex-1 flex items-center justify-center gap-2 border border-slate-300 rounded-lg px-3 py-2 text-sm cursor-pointer hover:bg-slate-50 has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-400">
                    <input type="radio" name="sens" value="C" required {{ (compte.sens ?? '') == 'C' ? 'checked' : '' }} class="sr-only">
                    Crédit
                </label>
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Catégorie <span class="text-slate-400 font-normal">(facultatif)</span></label>
            <input type="text" name="categorie" maxlength="100"
                   value="{{ compte.categorie ?? '' }}"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
    </div>

    <div class="flex items-center gap-3 mt-6 pt-4 border-t border-slate-200">
        <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm font-medium shadow-sm">
            {{ compte ? 'Enregistrer' : 'Créer' }}
        </button>
        <a href="/app/parametres/plan-comptable" class="text-sm text-slate-500 hover:text-slate-700">Annuler</a>
    </div>
</form>
{% endblock %}
