{% extends 'layout/app.html.twig' %}

{% block title %}Modifier le libellé - Plan comptable - ComptaV2{% endblock %}
{% block page_title %}Modifier le libellé du compte {{ row.numero }}{% endblock %}

{% set active_page = 'parametres' %}

{% block content %}
{% include 'app/parametres/_tabs.html.twig' %}

<div class="flex items-center gap-3 mb-6">
    <a href="/app/parametres/plan-comptable" class="text-slate-400 hover:text-slate-600 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h3 class="text-lg font-semibold text-slate-800">Retour au plan comptable</h3>
</div>

{% if session.error is defined %}
<div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">{{ session.error }}</div>
{% endif %}

<form method="POST" action="/app/parametres/plan-comptable/{{ row.numero }}" class="bg-white rounded-xl shadow-sm p-6 max-w-2xl">
    <div class="mb-4">
        <p class="text-sm text-slate-500">Compte <span class="font-mono font-semibold text-slate-700">{{ row.numero }}</span></p>
        <p class="text-sm text-slate-500 mt-1">Libellé affiché actuellement : <span class="font-medium text-slate-700">{{ row.libelle_effectif }}</span></p>
    </div>

    <div class="space-y-2 mb-4">
        <label class="block text-sm font-medium text-slate-700">Source du libellé</label>

        <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-300">
            <input type="radio" name="libelle_source" value="" {{ row.pref_libelle_source is null ? 'checked' : '' }} class="mt-0.5">
            <div class="flex-1">
                <div class="text-sm font-medium text-slate-700">Par défaut</div>
                <div class="text-xs text-slate-500">Suit le plan actif de l'entreprise.</div>
            </div>
        </label>

        {% if row.libelles.simplifie %}
        <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-300">
            <input type="radio" name="libelle_source" value="simplifie" {{ row.pref_libelle_source == 'simplifie' ? 'checked' : '' }} class="mt-0.5">
            <div class="flex-1">
                <div class="text-sm font-medium text-slate-700">Libellé simplifié</div>
                <div class="text-xs text-slate-500">{{ row.libelles.simplifie }}</div>
            </div>
        </label>
        {% endif %}

        {% if row.libelles.general %}
        <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-300">
            <input type="radio" name="libelle_source" value="general" {{ row.pref_libelle_source == 'general' ? 'checked' : '' }} class="mt-0.5">
            <div class="flex-1">
                <div class="text-sm font-medium text-slate-700">Libellé officiel (PCG)</div>
                <div class="text-xs text-slate-500">{{ row.libelles.general }}</div>
            </div>
        </label>
        {% endif %}

        <label class="flex items-start gap-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-300">
            <input type="radio" name="libelle_source" value="personnalise" id="src-perso" {{ row.pref_libelle_source == 'personnalise' ? 'checked' : '' }} class="mt-0.5">
            <div class="flex-1">
                <div class="text-sm font-medium text-slate-700">Personnalisé</div>
                <input type="text" id="libelle_perso" name="libelle_perso" maxlength="255"
                       value="{{ row.pref_libelle_perso }}"
                       placeholder="Votre libellé…"
                       class="mt-2 w-full border border-slate-300 rounded-lg px-3 py-1.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
            </div>
        </label>
    </div>

    <div class="flex items-center gap-3 pt-4 border-t border-slate-200">
        <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm font-medium shadow-sm">
            Enregistrer
        </button>
        <a href="/app/parametres/plan-comptable" class="text-sm text-slate-500 hover:text-slate-700">Annuler</a>
    </div>
</form>

<script>
// Sélectionne automatiquement "Personnalisé" quand on saisit dans le champ texte.
document.getElementById('libelle_perso').addEventListener('focus', function() {
    document.getElementById('src-perso').checked = true;
});
</script>
{% endblock %}
