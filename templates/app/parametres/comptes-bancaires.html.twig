{% extends 'layout/app.html.twig' %}

{% block title %}Comptes bancaires - Paramètres - ComptaV2{% endblock %}
{% block page_title %}Paramètres{% endblock %}

{% set active_page = 'parametres' %}

{% block content %}
{% include 'app/parametres/_tabs.html.twig' %}

{# Message de succès #}
{% if success == 'created' %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">
    Compte bancaire ajouté avec succès.
</div>
{% elseif success == 'updated' %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">
    Compte bancaire mis à jour avec succès.
</div>
{% elseif success == 'deleted' %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">
    Compte bancaire supprimé avec succès.
</div>
{% endif %}

{# Bouton ajouter #}
<div class="mb-6">
    <a href="/app/parametres/comptes-bancaires/create" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Ajouter un compte
    </a>
</div>

{# Liste des comptes #}
{% if comptes|length > 0 %}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Nom</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Banque</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">IBAN</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Connexion</th>
                <th class="text-right px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for compte in comptes %}
            <tr class="hover:bg-slate-50/80 transition">
                <td class="px-5 py-3.5 text-sm font-medium text-slate-800">{{ compte.nom }}</td>
                <td class="px-5 py-3.5 text-sm text-slate-600">{{ compte.banque }}</td>
                <td class="px-5 py-3.5 text-sm text-slate-500 font-mono">{{ compte.iban }}</td>
                <td class="px-5 py-3.5">
                    <span class="inline-flex items-center text-xs font-medium px-2 py-0.5 rounded-full
                        {{ compte.type_connexion == 'api' ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-600' }}">
                        {{ compte.type_connexion == 'api' ? 'API' : 'Manuel' }}
                    </span>
                </td>
                <td class="px-5 py-3.5 text-right whitespace-nowrap">
                    <a href="/app/parametres/comptes-bancaires/{{ compte.id }}/edit" class="inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800 transition mr-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Modifier
                    </a>
                    <form method="POST" action="/app/parametres/comptes-bancaires/{{ compte.id }}/delete" class="inline" onsubmit="return confirm('Supprimer le compte « {{ compte.nom }} » ?')">
                        <button type="submit" class="inline-flex items-center gap-1 text-sm text-red-600 hover:text-red-800 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            Supprimer
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="bg-white rounded-xl shadow-sm px-8 py-16 text-center">
    <h3 class="text-lg font-medium text-slate-600 mb-1">Aucun compte bancaire</h3>
    <p class="text-sm text-slate-400 mb-6">Ajoutez votre premier compte bancaire pour commencer.</p>
    <a href="/app/parametres/comptes-bancaires/create" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Ajouter un compte
    </a>
</div>
{% endif %}
{% endblock %}
