{% extends 'layout/app.html.twig' %}

{% block title %}Tableau de bord - ComptaV2{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% set active_page = 'dashboard' %}

{% block content %}

{# Sélecteur d'année #}
<div class="flex items-center gap-3 mb-6">
    <label class="text-sm font-medium text-slate-500">Exercice</label>
    <div class="flex rounded-lg border border-slate-300 overflow-hidden">
        {% for a in annees %}
        <a href="/app?annee={{ a }}"
           class="px-4 py-1.5 text-sm font-medium transition
           {{ a == annee ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-50' }}
           {{ not loop.last ? 'border-r border-slate-300' : '' }}">
            {{ a }}
        </a>
        {% endfor %}
    </div>
</div>

{# Solde bancaire #}
<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
    <div class="flex items-center justify-between">
        <div>
            <p class="text-sm text-slate-500">Solde au 01/01/{{ annee }}</p>
            <p class="text-xl font-bold {{ stats.solde_debut >= 0 ? 'text-slate-800' : 'text-red-600' }}">{{ stats.solde_debut|number_format(2, ',', ' ') }} &euro;</p>
        </div>
        <div class="text-center">
            <p class="text-sm text-slate-500">Variation</p>
            <p class="text-xl font-bold {{ stats.solde_variation >= 0 ? 'text-emerald-600' : 'text-red-600' }}">
                {{ stats.solde_variation >= 0 ? '+' : '' }}{{ stats.solde_variation|number_format(2, ',', ' ') }} &euro;
            </p>
        </div>
        <div class="text-right">
            <p class="text-sm text-slate-500">Solde {{ exercice_termine ? 'au 31/12/' ~ annee : "à aujourd'hui" }}</p>
            <p class="text-xl font-bold {{ stats.solde_fin >= 0 ? 'text-slate-800' : 'text-red-600' }}">{{ stats.solde_fin|number_format(2, ',', ' ') }} &euro;</p>
        </div>
    </div>
</div>

{# Tableau récapitulatif #}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Poste</th>
                <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Montant</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {# Revenus #}
            <tr class="bg-emerald-50/50">
                <td class="px-6 py-3.5 text-sm font-semibold text-emerald-800">Chiffre d'affaires HT</td>
                <td class="px-6 py-3.5 text-sm font-bold text-emerald-700 text-right tabular-nums">{{ stats.ca_ht|number_format(2, ',', ' ') }} &euro;</td>
            </tr>

            {# TVA #}
            <tr>
                <td class="px-6 py-3 text-sm text-slate-600 pl-10">TVA collectée (ventes)</td>
                <td class="px-6 py-3 text-sm text-slate-700 text-right tabular-nums">{{ stats.tva_entrant|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
            <tr>
                <td class="px-6 py-3 text-sm text-slate-600 pl-10">TVA déductible (achats)</td>
                <td class="px-6 py-3 text-sm text-slate-700 text-right tabular-nums">{{ stats.tva_sortant|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
            <tr class="{{ stats.tva_diff > 0 ? 'bg-amber-50/50' : 'bg-indigo-50/30' }}">
                <td class="px-6 py-3 text-sm font-medium {{ stats.tva_diff > 0 ? 'text-amber-800' : 'text-indigo-800' }} pl-10">TVA nette {{ stats.tva_diff > 0 ? 'à payer' : 'crédit' }}</td>
                <td class="px-6 py-3 text-sm font-semibold {{ stats.tva_diff > 0 ? 'text-amber-700' : 'text-indigo-700' }} text-right tabular-nums">{{ stats.tva_diff|abs|number_format(2, ',', ' ') }} &euro;</td>
            </tr>

            {# Charges #}
            <tr class="bg-red-50/30">
                <td class="px-6 py-3.5 text-sm font-semibold text-red-800">Total charges</td>
                <td class="px-6 py-3.5 text-sm font-bold text-red-700 text-right tabular-nums">{{ stats.charges|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
            <tr class="bg-red-50/20">
                <td class="px-6 py-3 text-sm font-medium text-red-700">Total impôts et taxes</td>
                <td class="px-6 py-3 text-sm font-semibold text-red-600 text-right tabular-nums">{{ stats.impots|number_format(2, ',', ' ') }} &euro;</td>
            </tr>

            {# Résultat #}
            <tr class="bg-slate-100 border-t-2 border-slate-300">
                <td class="px-6 py-4 text-sm font-bold text-slate-800">Bénéfice imposable</td>
                <td class="px-6 py-4 text-sm font-bold {{ stats.benefice >= 0 ? 'text-emerald-700' : 'text-red-700' }} text-right tabular-nums">{{ stats.benefice|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
            <tr>
                <td class="px-6 py-3 text-sm text-slate-600 pl-10">Bénéfice mensuel moyen</td>
                <td class="px-6 py-3 text-sm {{ stats.benefice_mensuel >= 0 ? 'text-emerald-600' : 'text-red-600' }} text-right tabular-nums font-medium">{{ stats.benefice_mensuel|number_format(2, ',', ' ') }} &euro;</td>
            </tr>

            {# Prélèvements #}
            <tr>
                <td class="px-6 py-3 text-sm font-medium text-slate-700">Avances / prélèvements associé</td>
                <td class="px-6 py-3 text-sm font-semibold text-slate-700 text-right tabular-nums">{{ stats.prelevements|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
        </tbody>
    </table>
</div>

{% endblock %}
