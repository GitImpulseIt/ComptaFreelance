{% extends 'layout/base.html.twig' %}

{% block title %}Connexion - ComptaV2{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-indigo-500 via-blue-600 to-indigo-700">
    <div class="w-full max-w-sm">
        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-indigo-100 rounded-xl mb-4">
                    <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-slate-800">ComptaV2</h1>
                <p class="text-sm text-slate-500 mt-1">Connectez-vous à votre espace</p>
            </div>
            {% if error is defined and error %}
            <div class="mb-4 px-4 py-3 bg-red-50 border-l-4 border-red-500 rounded-r-lg text-sm text-red-700">
                {{ error }}
            </div>
            {% endif %}
            <form method="POST" action="/auth/login" class="space-y-5">
                <div>
                    <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" id="email" name="email" required
                           placeholder="vous@exemple.fr" class="block w-full">
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Mot de passe</label>
                    <input type="password" id="password" name="password" required
                           placeholder="Votre mot de passe" class="block w-full">
                </div>
                <button type="submit"
                        class="w-full bg-indigo-600 text-white py-2.5 px-4 rounded-lg hover:bg-indigo-700 active:bg-indigo-800 transition font-medium shadow-sm">
                    Se connecter
                </button>
            </form>
            <p class="mt-6 text-center text-sm text-slate-500">
                Pas encore de compte ? <a href="/auth/register" class="text-indigo-600 font-medium hover:underline">S'inscrire</a>
            </p>
        </div>
        <p class="text-center text-indigo-200 text-xs mt-6">ComptaV2 — Comptabilité freelance</p>
    </div>
</div>
{% endblock %}
