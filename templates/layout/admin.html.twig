{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="flex h-screen">
    {# Sidebar admin #}
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-6 border-b border-gray-700">
            <h1 class="text-xl font-bold">ComptaV2</h1>
            <p class="text-sm text-gray-400">Administration</p>
        </div>
        <nav class="flex-1 p-4 space-y-1">
            <a href="/admin" class="block px-4 py-2 rounded-lg hover:bg-gray-800">Tableau de bord</a>
            <a href="/admin/entreprises" class="block px-4 py-2 rounded-lg hover:bg-gray-800">Entreprises</a>
            <a href="/admin/users" class="block px-4 py-2 rounded-lg hover:bg-gray-800">Utilisateurs</a>
            <a href="/admin/banque" class="block px-4 py-2 rounded-lg hover:bg-gray-800">Banque</a>
        </nav>
        <div class="p-4 border-t border-gray-700">
            <a href="/app" class="text-sm text-gray-400 hover:text-white">Retour à l'app</a>
        </div>
    </aside>

    {# Contenu principal #}
    <main class="flex-1 overflow-y-auto">
        <header class="bg-white border-b border-gray-200 px-8 py-4">
            <h2 class="text-2xl font-semibold text-gray-800">{% block page_title %}{% endblock %}</h2>
        </header>
        <div class="p-8">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
