{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="flex h-screen">
    <aside class="w-64 bg-gradient-to-b from-slate-900 to-slate-800 text-white flex flex-col">
        <div class="p-6 border-b border-slate-700/50">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-indigo-500 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-lg font-bold">ComptaV2</h1>
                    <p class="text-xs text-slate-400">{{ entreprise.raison_sociale ?? '' }}</p>
                </div>
            </div>
        </div>
        <nav class="flex-1 p-3 space-y-1 mt-2">
            <a href="/app" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'dashboard' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Tableau de bord
            </a>
            <a href="/app/clients" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'clients' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                Clients
            </a>
            <a href="/app/factures" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'factures' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Factures
            </a>
            <a href="/app/depenses" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'depenses' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                Dépenses
            </a>
            <a href="/app/banque" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'banque' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                Opérations bancaires
            </a>
            {% if entreprise.regime_tva is defined and entreprise.regime_tva != 'franchise' %}
            {% if entreprise.regime_tva == 'reel_simplifie' %}
            <a href="/app/tva" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'tva' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
                TVA
            </a>
            {% else %}
            <span class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm text-slate-500 cursor-not-allowed" title="Bientôt disponible pour le régime normal">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
                TVA
            </span>
            {% endif %}
            {% endif %}
            <a href="/app/immobilisations" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'immobilisations' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                Immobilisations
            </a>
            {% if entreprise.regime_benefices is defined and entreprise.regime_benefices == 'BNC' %}
            <a href="/app/cloture" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'cloture' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Clôture d'exercice
            </a>
            {% endif %}
            <a href="/app/parametres" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition
                {% if active_page is defined and active_page == 'parametres' %}bg-indigo-600 text-white{% else %}text-slate-300 hover:bg-slate-700/50 hover:text-white{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Paramètres
            </a>
        </nav>
        <div class="p-4 border-t border-slate-700/50">
            <form action="/auth/logout" method="POST">
                <button type="submit" class="flex items-center gap-3 px-4 py-2 rounded-lg text-sm text-slate-400 hover:bg-slate-700/50 hover:text-white transition w-full text-left">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Déconnexion
                </button>
            </form>
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto bg-slate-50">
        <header class="bg-white border-b border-slate-200 px-8 py-5 flex items-center justify-between">
            <h2 class="text-2xl font-bold text-slate-800">{% block page_title %}{% endblock %}</h2>
            {% if current_user is defined and current_user %}
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
                    <span class="text-xs font-bold text-indigo-600">{{ current_user.prenom|first }}{{ current_user.nom|first }}</span>
                </div>
                <span class="text-sm text-slate-600">{{ current_user.prenom }} {{ current_user.nom }}</span>
            </div>
            {% endif %}
        </header>
        <div class="p-8">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
