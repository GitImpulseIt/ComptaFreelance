{% extends 'layout/app.html.twig' %}

{% block title %}{{ user.prenom }} {{ user.nom }} - ComptaV2 Admin{% endblock %}
{% block page_title %}{{ user.prenom }} {{ user.nom }}{% endblock %}

{% set active_page = 'users' %}

{% block content %}
<div class="flex gap-3 mb-8">
    <a href="/users/{{ user.id }}/edit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Modifier
    </a>
    <form action="/users/{{ user.id }}/reset-password" method="POST"
          onsubmit="return confirm('Réinitialiser le mot de passe de cet utilisateur ?');">
        <button type="submit" class="inline-flex items-center gap-2 bg-amber-600 text-white px-4 py-2 rounded-lg hover:bg-amber-700 transition font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            Réinitialiser le mot de passe
        </button>
    </form>
    <a href="/users" class="border border-slate-300 text-slate-600 px-4 py-2 rounded-lg hover:bg-slate-50 transition font-medium">Retour</a>
</div>

<div class="bg-white rounded-xl shadow-sm p-6 max-w-lg">
    <dl class="space-y-3 text-sm">
        <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Prénom</dt><dd class="font-medium text-slate-700">{{ user.prenom }}</dd></div>
        <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Nom</dt><dd class="font-medium text-slate-700">{{ user.nom }}</dd></div>
        <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Email</dt><dd class="text-slate-700">{{ user.email }}</dd></div>
        <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Entreprise</dt><dd>
            <a href="/entreprises/{{ user.entreprise_id }}" class="text-indigo-600 hover:underline font-medium">{{ user.entreprise_nom }}</a>
        </dd></div>
        <div class="flex justify-between py-1"><dt class="text-slate-500">Inscription</dt><dd class="text-slate-700">{{ user.created_at|date('d/m/Y H:i') }}</dd></div>
    </dl>
</div>
{% endblock %}
