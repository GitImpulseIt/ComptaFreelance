{% extends 'layout/app.html.twig' %}

{% block title %}Mot de passe réinitialisé - ComptaV2 Admin{% endblock %}
{% block page_title %}Mot de passe réinitialisé{% endblock %}

{% set active_page = 'users' %}

{% block content %}
<div class="max-w-lg">
    <div class="bg-amber-50 border border-amber-300 rounded-xl p-6 mb-6">
        <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
                <h3 class="font-semibold text-amber-800">Attention</h3>
                <p class="text-sm text-amber-700 mt-1">
                    Une fois cette page fermée, le mot de passe ne sera plus jamais accessible.
                    Communiquez-le immédiatement à l'utilisateur.
                </p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6">
        <p class="text-sm text-gray-500 mb-2">Utilisateur : <strong>{{ user.prenom }} {{ user.nom }}</strong> ({{ user.email }})</p>
        <p class="text-sm text-gray-500 mb-4">Nouveau mot de passe :</p>
        <div class="bg-gray-900 text-green-400 font-mono text-lg px-6 py-4 rounded-lg select-all text-center tracking-wider">
            {{ new_password }}
        </div>
    </div>

    <div class="mt-6">
        <a href="/users/{{ user.id }}" class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
            Retour à la fiche utilisateur
        </a>
    </div>
</div>
{% endblock %}
