{% extends 'layout/app.html.twig' %}

{% block title %}Utilisateurs - ComptaV2 Admin{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}

{% set active_page = 'users' %}

{% block content %}
<div class="mb-6">
    <a href="/users/create" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2.5 rounded-lg hover:bg-indigo-700 active:bg-indigo-800 transition font-medium shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nouvel utilisateur
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wider">
            <tr>
                <th class="px-6 py-3.5 text-left font-semibold">Nom</th>
                <th class="px-6 py-3.5 text-left font-semibold">Email</th>
                <th class="px-6 py-3.5 text-left font-semibold">Entreprise</th>
                <th class="px-6 py-3.5 text-left font-semibold">Inscription</th>
                <th class="px-6 py-3.5"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for u in users %}
            <tr class="hover:bg-slate-50/50 transition">
                <td class="px-6 py-4 font-medium text-slate-800">{{ u.prenom }} {{ u.nom }}</td>
                <td class="px-6 py-4 text-slate-500">{{ u.email }}</td>
                <td class="px-6 py-4">
                    <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-indigo-50 text-indigo-700 ring-1 ring-indigo-200">{{ u.entreprise_nom }}</span>
                </td>
                <td class="px-6 py-4 text-slate-500">{{ u.created_at|date('d/m/Y') }}</td>
                <td class="px-6 py-4 text-right space-x-3">
                    <a href="/users/{{ u.id }}" class="text-indigo-600 hover:text-indigo-800 font-medium">Voir</a>
                    <a href="/users/{{ u.id }}/edit" class="text-slate-400 hover:text-slate-600 font-medium">Modifier</a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="px-6 py-12 text-center text-slate-400">Aucun utilisateur enregistré.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
