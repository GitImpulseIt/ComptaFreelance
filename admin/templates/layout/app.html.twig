{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="flex h-screen">
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-6 border-b border-gray-700">
            <h1 class="text-xl font-bold">ComptaV2</h1>
            <p class="text-sm text-gray-400">Administration</p>
        </div>
        <nav class="flex-1 p-4 space-y-1">
            <a href="/dashboard" class="block px-4 py-2 rounded-lg hover:bg-gray-800 {% if active_page is defined and active_page == 'dashboard' %}bg-gray-800{% endif %}">Tableau de bord</a>
            <a href="/entreprises" class="block px-4 py-2 rounded-lg hover:bg-gray-800 {% if active_page is defined and active_page == 'entreprises' %}bg-gray-800{% endif %}">Entreprises</a>
            <a href="/users" class="block px-4 py-2 rounded-lg hover:bg-gray-800 {% if active_page is defined and active_page == 'users' %}bg-gray-800{% endif %}">Utilisateurs</a>
            <a href="/banque" class="block px-4 py-2 rounded-lg hover:bg-gray-800 {% if active_page is defined and active_page == 'banque' %}bg-gray-800{% endif %}">Banque</a>
        </nav>
        <div class="p-4 border-t border-gray-700 space-y-2">
            <a href="/password" class="block text-sm text-gray-400 hover:text-white">Changer le mot de passe</a>
            <form action="/logout" method="POST">
                <button type="submit" class="text-sm text-gray-400 hover:text-white">Déconnexion</button>
            </form>
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto">
        <header class="bg-white border-b border-gray-200 px-8 py-4">
            <h2 class="text-2xl font-semibold text-gray-800">{% block page_title %}{% endblock %}</h2>
        </header>
        <div class="p-8">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
