{% set c = compte ?? {} %}

<div class="space-y-4">
    {% if not is_edit %}
    <div>
        <label for="numero" class="block text-sm font-medium text-slate-700 mb-1">Numéro</label>
        <input type="text" id="numero" name="numero" required pattern="\d{2,10}" inputmode="numeric"
               placeholder="ex. 606300"
               class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none font-mono">
        <p class="mt-1 text-xs text-slate-500">2 à 10 chiffres. Doit être unique.</p>
    </div>
    {% else %}
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Numéro</label>
        <input type="text" value="{{ c.numero }}" disabled
               class="w-full border border-slate-200 bg-slate-50 rounded-lg px-3 py-2 text-sm font-mono text-slate-500">
    </div>
    {% endif %}

    <div>
        <label for="libelle" class="block text-sm font-medium text-slate-700 mb-1">Libellé</label>
        <input type="text" id="libelle" name="libelle" required maxlength="255"
               value="{{ c.libelle ?? '' }}"
               class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div>
            <label for="categorie" class="block text-sm font-medium text-slate-700 mb-1">Catégorie</label>
            <input type="text" id="categorie" name="categorie" required maxlength="100" list="categories-list"
                   value="{{ c.categorie ?? '' }}"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
            <datalist id="categories-list">
                {% for cat in categories %}
                <option value="{{ cat }}">
                {% endfor %}
            </datalist>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Sens</label>
            <div class="flex gap-2">
                <label class="flex-1 flex items-center justify-center gap-2 border border-slate-300 rounded-lg px-3 py-2 text-sm cursor-pointer hover:bg-slate-50 has-[:checked]:bg-red-50 has-[:checked]:border-red-400">
                    <input type="radio" name="sens" value="D" required {{ (c.sens ?? '') == 'D' ? 'checked' : '' }} class="sr-only">
                    Débit
                </label>
                <label class="flex-1 flex items-center justify-center gap-2 border border-slate-300 rounded-lg px-3 py-2 text-sm cursor-pointer hover:bg-slate-50 has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-400">
                    <input type="radio" name="sens" value="C" required {{ (c.sens ?? '') == 'C' ? 'checked' : '' }} class="sr-only">
                    Crédit
                </label>
            </div>
        </div>
    </div>

    <div>
        <label for="mots_cles" class="block text-sm font-medium text-slate-700 mb-1">Mots-clés</label>
        <input type="text" id="mots_cles" name="mots_cles" maxlength="500"
               value="{{ c.mots_cles ?? '' }}"
               placeholder="mot1|mot2|expression"
               class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        <p class="mt-1 text-xs text-slate-500">Séparés par <code>|</code>. Aident la recherche dans l'autocomplete.</p>
    </div>

    <div>
        <label for="exemples" class="block text-sm font-medium text-slate-700 mb-1">Exemples</label>
        <textarea id="exemples" name="exemples" rows="2" maxlength="500"
                  class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">{{ c.exemples ?? '' }}</textarea>
    </div>

    <div>
        <label for="pcg_parent" class="block text-sm font-medium text-slate-700 mb-1">Compte PCG parent <span class="text-slate-400 font-normal">(facultatif)</span></label>
        <input type="text" id="pcg_parent" name="pcg_parent" maxlength="10"
               value="{{ c.pcg_parent ?? '' }}"
               placeholder="ex. 606"
               class="w-32 border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none font-mono">
    </div>
</div>
