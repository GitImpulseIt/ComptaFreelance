{% extends 'layout/app.html.twig' %}

{% block title %}Nouveau compte simplifié - Admin{% endblock %}
{% block page_title %}Nouveau compte simplifié{% endblock %}

{% set active_page = 'plan-comptable-simplifie' %}

{% block content %}

<div class="flex items-center gap-3 mb-6">
    <a href="/plan-comptable-simplifie" class="text-slate-400 hover:text-slate-600 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h3 class="text-lg font-semibold text-slate-800">Retour au plan simplifié</h3>
</div>

{% if session.error is defined %}
<div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">{{ session.error }}</div>
{% endif %}

<form method="POST" action="/plan-comptable-simplifie" class="bg-white rounded-xl shadow-sm p-6 max-w-2xl">
    {% include 'plan-comptable-simplifie/_form.html.twig' with {is_edit: false} %}

    <div class="flex items-center gap-3 mt-6 pt-4 border-t border-slate-200">
        <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm font-medium shadow-sm">
            Créer
        </button>
        <a href="/plan-comptable-simplifie" class="text-sm text-slate-500 hover:text-slate-700">Annuler</a>
    </div>
</form>

{% endblock %}
