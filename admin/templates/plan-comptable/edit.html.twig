{% extends 'layout/app.html.twig' %}

{% block title %}Modifier compte {{ compte.numero }} - Admin{% endblock %}
{% block page_title %}Modifier le compte {{ compte.numero }}{% endblock %}

{% set active_page = 'plan-comptable' %}

{% block content %}

<div class="flex items-center gap-3 mb-6">
    <a href="/plan-comptable?classe={{ compte.classe }}" class="text-slate-400 hover:text-slate-600 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h3 class="text-lg font-semibold text-slate-800">Retour au plan comptable</h3>
</div>

{% if session.error is defined %}
<div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">{{ session.error }}</div>
{% endif %}

<form method="POST" action="/plan-comptable/{{ compte.numero }}" class="bg-white rounded-xl shadow-sm p-6 max-w-xl">
    <div class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Numéro</label>
            <input type="text" value="{{ compte.numero }}" disabled
                   class="w-full border border-slate-200 bg-slate-50 rounded-lg px-3 py-2 text-sm font-mono text-slate-500">
            <p class="mt-1 text-xs text-slate-500">Le numéro ne peut pas être modifié.</p>
        </div>
        <div>
            <label for="libelle" class="block text-sm font-medium text-slate-700 mb-1">Libellé</label>
            <input type="text" id="libelle" name="libelle" required maxlength="255"
                   value="{{ compte.libelle }}"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div>
            <label for="classe" class="block text-sm font-medium text-slate-700 mb-1">Classe</label>
            <select id="classe" name="classe" required class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
                {% for c in 1..9 %}
                <option value="{{ c }}" {{ compte.classe == c ? 'selected' : '' }}>
                    Classe {{ c }}{% if c == 1 %} — Capitaux{% elseif c == 2 %} — Immobilisations{% elseif c == 3 %} — Stocks{% elseif c == 4 %} — Tiers{% elseif c == 5 %} — Financiers{% elseif c == 6 %} — Charges{% elseif c == 7 %} — Produits{% elseif c == 8 %} — Spéciaux{% elseif c == 9 %} — Analytiques{% endif %}
                </option>
                {% endfor %}
            </select>
        </div>
        <label class="flex items-center gap-2">
            <input type="checkbox" name="optionnel" value="1" {{ compte.optionnel ? 'checked' : '' }}
                   class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
            <span class="text-sm text-slate-700">Compte optionnel (masqué dans la sélection de qualification)</span>
        </label>
    </div>

    <div class="flex items-center gap-3 mt-6 pt-4 border-t border-slate-200">
        <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm font-medium shadow-sm">
            Enregistrer
        </button>
        <a href="/plan-comptable?classe={{ compte.classe }}" class="text-sm text-slate-500 hover:text-slate-700">Annuler</a>
    </div>
</form>

{% endblock %}
