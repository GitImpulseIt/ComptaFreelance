{% extends 'layout/base.html.twig' %}

{% block title %}Connexion - ComptaV2 Admin{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-indigo-600 via-purple-600 to-indigo-800">
    <div class="w-full max-w-sm">
        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-indigo-100 rounded-xl mb-4">
                    <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-gray-800">ComptaV2</h1>
                <p class="text-sm text-gray-500 mt-1">Espace administration</p>
            </div>
            {% if error %}
            <div class="mb-4 px-4 py-3 bg-red-50 border-l-4 border-red-500 rounded-r-lg text-sm text-red-700">
                {{ error }}
            </div>
            {% endif %}
            <form method="POST" action="/login" class="space-y-5">
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
                    <input type="password" id="password" name="password" required autofocus
                           placeholder="Entrez votre mot de passe"
                           class="block w-full">
                </div>
                <button type="submit"
                        class="w-full bg-indigo-600 text-white py-2.5 px-4 rounded-lg hover:bg-indigo-700 active:bg-indigo-800 transition font-medium shadow-sm">
                    Se connecter
                </button>
            </form>
        </div>
        <p class="text-center text-indigo-200 text-xs mt-6">ComptaV2 Administration</p>
    </div>
</div>
{% endblock %}
