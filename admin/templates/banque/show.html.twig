{% extends 'layout/app.html.twig' %}

{% block title %}{{ compte.nom }} - ComptaV2 Admin{% endblock %}
{% block page_title %}{{ compte.nom }}{% endblock %}

{% set active_page = 'banque' %}

{% block content %}
<div class="mb-6">
    <a href="/banque" class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50 transition">Retour</a>
</div>

<div class="bg-white rounded-xl shadow-sm p-6 max-w-lg mb-8">
    <dl class="space-y-3 text-sm">
        <div class="flex justify-between"><dt class="text-gray-500">Entreprise</dt><dd>{{ compte.entreprise_nom }}</dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">Banque</dt><dd>{{ compte.banque }}</dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">IBAN</dt><dd>{{ compte.iban }}</dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">Type</dt><dd>{{ compte.type_connexion }}</dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">Dernière synchro</dt><dd>{{ compte.derniere_synchro|date('d/m/Y H:i') ?? '-' }}</dd></div>
    </dl>
</div>

<h3 class="text-lg font-semibold mb-4">Historique des imports</h3>
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
            <tr>
                <th class="px-6 py-3 text-left">Date</th>
                <th class="px-6 py-3 text-center">Source</th>
                <th class="px-6 py-3 text-center">Format</th>
                <th class="px-6 py-3 text-center">Transactions</th>
                <th class="px-6 py-3 text-center">Statut</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for i in imports %}
            <tr>
                <td class="px-6 py-4">{{ i.created_at|date('d/m/Y H:i') }}</td>
                <td class="px-6 py-4 text-center">{{ i.source }}</td>
                <td class="px-6 py-4 text-center">{{ i.format }}</td>
                <td class="px-6 py-4 text-center">{{ i.nb_transactions }}</td>
                <td class="px-6 py-4 text-center">
                    <span class="px-2 py-1 text-xs rounded-full
                        {{ i.statut == 'termine' ? 'bg-green-100 text-green-700' :
                           (i.statut == 'erreur' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700') }}">
                        {{ i.statut }}
                    </span>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="px-6 py-8 text-center text-gray-400">Aucun import.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
