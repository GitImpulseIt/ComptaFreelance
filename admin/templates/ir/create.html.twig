{% extends 'layout/app.html.twig' %}

{% block title %}Nouveau barème IR - Admin{% endblock %}
{% block page_title %}Barème IR{% endblock %}

{% set active_page = 'ir' %}

{% block content %}
<div class="max-w-lg">
    <div class="flex items-center gap-3 mb-6">
        <a href="/ir" class="text-slate-400 hover:text-slate-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <h3 class="text-lg font-semibold text-slate-800">Nouveau barème</h3>
    </div>

    {% if session.error is defined and session.error %}
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">{{ session.error }}</div>
    {% endif %}

    <form method="POST" action="/ir" class="bg-white rounded-xl shadow-sm p-6 space-y-5">
        <div>
            <label for="annee" class="block text-sm font-medium text-slate-700 mb-1">Année</label>
            <input type="number" id="annee" name="annee" required min="2020" max="2050"
                   value="{{ "now"|date("Y") + 1 }}"
                   class="w-32 border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Tranches</label>
            <p class="text-xs text-slate-500 mb-3">Saisissez le plafond de chaque tranche et son taux. La dernière tranche n'a pas de plafond.</p>
            <table class="w-full" id="tranches-table">
                <thead>
                    <tr class="text-xs text-slate-500">
                        <th class="text-left pb-1">Jusqu'à (&euro;)</th>
                        <th class="text-left pb-1">Taux (%)</th>
                        <th class="w-10"></th>
                    </tr>
                </thead>
                <tbody id="tranches-body">
                    <tr class="tranche-row"><td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="11497" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pr-2 pb-2"><input type="text" name="taux[]" value="0" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pb-2"><button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></td></tr>
                    <tr class="tranche-row"><td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="29315" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pr-2 pb-2"><input type="text" name="taux[]" value="11" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pb-2"><button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></td></tr>
                    <tr class="tranche-row"><td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="83823" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pr-2 pb-2"><input type="text" name="taux[]" value="30" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pb-2"><button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></td></tr>
                    <tr class="tranche-row"><td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="180294" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pr-2 pb-2"><input type="text" name="taux[]" value="41" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td class="pb-2"><button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></td></tr>
                    <tr class="tranche-row"><td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="" placeholder="Au-delà" disabled class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-slate-50 text-slate-400"></td><td class="pr-2 pb-2"><input type="text" name="taux[]" value="45" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td><td></td></tr>
                </tbody>
            </table>
            <button type="button" id="add-tranche" class="mt-2 inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Ajouter une tranche
            </button>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Créer
            </button>
            <a href="/ir" class="inline-flex items-center px-4 py-2.5 border border-slate-300 text-slate-600 rounded-lg hover:bg-slate-50 transition text-sm">Annuler</a>
        </div>
    </form>
</div>

<script>
document.getElementById('add-tranche').addEventListener('click', function() {
    var tbody = document.getElementById('tranches-body');
    var lastRow = tbody.querySelector('.tranche-row:last-child');
    // Réactiver le max de l'ancienne dernière ligne
    var lastMax = lastRow.querySelector('input[name="tranche_max[]"]');
    lastMax.disabled = false;
    lastMax.placeholder = '';
    lastMax.classList.remove('bg-slate-50', 'text-slate-400', 'border-slate-200');
    lastMax.classList.add('border-slate-300');
    // Ajouter le bouton supprimer à l'ancienne dernière ligne si absent
    var lastTd = lastRow.querySelector('td:last-child');
    if (!lastTd.querySelector('.remove-tranche')) {
        lastTd.innerHTML = '<button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>';
    }
    // Nouvelle dernière ligne
    var tr = document.createElement('tr');
    tr.className = 'tranche-row';
    tr.innerHTML = '<td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="" placeholder="Au-delà" disabled class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-slate-50 text-slate-400"></td>' +
        '<td class="pr-2 pb-2"><input type="text" name="taux[]" value="" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>' +
        '<td></td>';
    tbody.appendChild(tr);
    lastMax.focus();
});

document.getElementById('tranches-body').addEventListener('click', function(e) {
    var btn = e.target.closest('.remove-tranche');
    if (btn) {
        var rows = document.querySelectorAll('.tranche-row');
        if (rows.length > 2) btn.closest('tr').remove();
    }
});
</script>
{% endblock %}
