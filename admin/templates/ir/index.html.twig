{% extends 'layout/app.html.twig' %}

{% block title %}Barème IR - Admin{% endblock %}
{% block page_title %}Barème IR{% endblock %}

{% set active_page = 'ir' %}

{% block content %}

{% if success == 'created' %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">Barème créé avec succès.</div>
{% elseif success == 'updated' %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">Barème mis à jour.</div>
{% elseif success == 'deleted' %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm">Barème supprimé.</div>
{% elseif success == 'exists' %}
<div class="mb-4 px-4 py-3 bg-amber-50 border border-amber-200 text-amber-700 rounded-lg text-sm">Le barème de l'année suivante existe déjà.</div>
{% endif %}

<div class="mb-6">
    <a href="/ir/create" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nouveau barème
    </a>
</div>

{% if annees|length > 0 %}
<div class="space-y-6">
    {% for annee in annees %}
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200">
            <h3 class="text-lg font-bold text-slate-800">{{ annee }}</h3>
            <div class="flex gap-2">
                <form method="POST" action="/ir/{{ annee }}/duplicate" class="inline">
                    <button type="submit" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-indigo-600 transition" title="Dupliquer vers {{ annee + 1 }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                        Dupliquer
                    </button>
                </form>
                <a href="/ir/{{ annee }}/edit" class="inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Modifier
                </a>
                <form method="POST" action="/ir/{{ annee }}/delete" class="inline" onsubmit="return confirm('Supprimer le barème {{ annee }} ?')">
                    <button type="submit" class="inline-flex items-center gap-1 text-sm text-red-600 hover:text-red-800 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Supprimer
                    </button>
                </form>
            </div>
        </div>
        <table class="w-full">
            <thead>
                <tr class="bg-slate-50">
                    <th class="text-left px-6 py-2 text-xs font-semibold text-slate-500 uppercase">De</th>
                    <th class="text-left px-6 py-2 text-xs font-semibold text-slate-500 uppercase">À</th>
                    <th class="text-right px-6 py-2 text-xs font-semibold text-slate-500 uppercase">Taux</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for t in tranches_par_annee[annee] %}
                <tr>
                    <td class="px-6 py-2.5 text-sm text-slate-700 tabular-nums">{{ t.tranche_min|number_format(0, ',', ' ') }} &euro;</td>
                    <td class="px-6 py-2.5 text-sm text-slate-700 tabular-nums">{{ t.tranche_max ? t.tranche_max|number_format(0, ',', ' ') ~ ' €' : '∞' }}</td>
                    <td class="px-6 py-2.5 text-sm font-semibold text-slate-800 text-right tabular-nums">{{ t.taux|number_format(1, ',', ' ') }} %</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="bg-white rounded-xl shadow-sm px-8 py-16 text-center">
    <h3 class="text-lg font-medium text-slate-600 mb-1">Aucun barème IR défini</h3>
    <p class="text-sm text-slate-400">Créez un barème pour commencer.</p>
</div>
{% endif %}

{% endblock %}
