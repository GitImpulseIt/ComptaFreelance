{% extends 'layout/app.html.twig' %}

{% block title %}Modifier barème IR {{ annee }} - Admin{% endblock %}
{% block page_title %}Barème IR{% endblock %}

{% set active_page = 'ir' %}

{% block content %}
<div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="/ir" class="text-slate-400 hover:text-slate-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <h3 class="text-lg font-semibold text-slate-800">Barème {{ annee }}</h3>
    </div>

    <form method="POST" action="/ir/{{ annee }}" class="bg-white rounded-xl shadow-sm p-6 space-y-5">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Tranches</label>
            <table class="w-full" id="tranches-table">
                <thead>
                    <tr class="text-xs text-slate-500">
                        <th class="text-left pb-1">Min (&euro;)</th>
                        <th class="text-left pb-1">Max (&euro;)</th>
                        <th class="text-left pb-1">Taux (%)</th>
                        <th class="w-10"></th>
                    </tr>
                </thead>
                <tbody id="tranches-body">
                    {% for t in tranches %}
                    <tr class="tranche-row">
                        <td class="pr-2 pb-2"><input type="text" name="tranche_min[]" value="{{ t.tranche_min|number_format(0, '', '') }}" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>
                        <td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="{{ t.tranche_max ? t.tranche_max|number_format(0, '', '') : '' }}" placeholder="∞" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>
                        <td class="pr-2 pb-2"><input type="text" name="taux[]" value="{{ t.taux|number_format(1, '.', '') }}" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>
                        <td class="pb-2">{% if not loop.first %}<button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>{% endif %}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            <button type="button" id="add-tranche" class="mt-2 inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Ajouter une tranche
            </button>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-2.5 rounded-lg hover:bg-indigo-700 transition font-medium text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Enregistrer
            </button>
            <a href="/ir" class="inline-flex items-center px-4 py-2.5 border border-slate-300 text-slate-600 rounded-lg hover:bg-slate-50 transition text-sm">Annuler</a>
        </div>
    </form>
</div>

<script>
document.getElementById('add-tranche').addEventListener('click', function() {
    var tbody = document.getElementById('tranches-body');
    var tr = document.createElement('tr');
    tr.className = 'tranche-row';
    tr.innerHTML = '<td class="pr-2 pb-2"><input type="text" name="tranche_min[]" value="" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>' +
        '<td class="pr-2 pb-2"><input type="text" name="tranche_max[]" value="" placeholder="∞" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>' +
        '<td class="pr-2 pb-2"><input type="text" name="taux[]" value="" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></td>' +
        '<td class="pb-2"><button type="button" class="remove-tranche text-slate-400 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></td>';
    tbody.appendChild(tr);
    tr.querySelector('input').focus();
});

document.getElementById('tranches-body').addEventListener('click', function(e) {
    var btn = e.target.closest('.remove-tranche');
    if (btn) {
        var rows = document.querySelectorAll('.tranche-row');
        if (rows.length > 1) btn.closest('tr').remove();
    }
});
</script>
{% endblock %}
