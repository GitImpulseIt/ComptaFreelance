{% extends 'layout/app.html.twig' %}

{% block title %}{{ entreprise.raison_sociale }} - ComptaV2 Admin{% endblock %}
{% block page_title %}{{ entreprise.raison_sociale }}{% endblock %}

{% set active_page = 'entreprises' %}

{% block content %}
<div class="flex gap-3 mb-8">
    <a href="/entreprises/{{ entreprise.id }}/edit" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Modifier
    </a>
    <form action="/entreprises/{{ entreprise.id }}/suspend" method="POST">
        <button type="submit" class="inline-flex items-center gap-2 {{ entreprise.active ? 'bg-red-600 hover:bg-red-700' : 'bg-emerald-600 hover:bg-emerald-700' }} text-white px-4 py-2 rounded-lg transition font-medium">
            {{ entreprise.active ? 'Suspendre' : 'Réactiver' }}
        </button>
    </form>
    <form action="/entreprises/{{ entreprise.id }}/delete" method="POST"
          onsubmit="return confirm('Supprimer définitivement cette entreprise ?');">
        <button type="submit" class="inline-flex items-center gap-2 border border-red-300 text-red-600 px-4 py-2 rounded-lg hover:bg-red-50 transition font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Supprimer
        </button>
    </form>
    <a href="/entreprises" class="border border-slate-300 text-slate-600 px-4 py-2 rounded-lg hover:bg-slate-50 transition font-medium">Retour</a>
</div>

{% if error is defined and error %}
<div class="mb-6 px-4 py-3 bg-red-50 border-l-4 border-red-500 rounded-r-lg text-sm text-red-700">{{ error }}</div>
{% endif %}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="text-base font-semibold text-slate-800 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Informations
        </h3>
        <dl class="space-y-3 text-sm">
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">SIRET</dt><dd class="font-mono text-slate-700">{{ entreprise.siret }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Adresse</dt><dd class="text-slate-700">{{ entreprise.adresse }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Ville</dt><dd class="text-slate-700">{{ entreprise.code_postal }} {{ entreprise.ville }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Téléphone</dt><dd class="text-slate-700">{{ entreprise.telephone }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Email</dt><dd class="text-slate-700">{{ entreprise.email }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Régime TVA</dt><dd class="text-slate-700">{{ entreprise.regime_tva }}</dd></div>
            <div class="flex justify-between py-1"><dt class="text-slate-500">Statut</dt><dd>
                {% if entreprise.active %}
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-emerald-50 text-emerald-700">Active</span>
                {% else %}
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-red-50 text-red-700">Suspendue</span>
                {% endif %}
            </dd></div>
        </dl>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="text-base font-semibold text-slate-800 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Statistiques
        </h3>
        <dl class="space-y-3 text-sm">
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Utilisateurs</dt><dd class="font-medium text-slate-700">{{ entreprise.nb_users }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">Factures</dt><dd class="font-medium text-slate-700">{{ entreprise.nb_factures }}</dd></div>
            <div class="flex justify-between py-1 border-b border-slate-50"><dt class="text-slate-500">CA total</dt><dd class="font-bold text-indigo-600">{{ entreprise.ca_total|number_format(2, ',', ' ') }} &euro;</dd></div>
            <div class="flex justify-between py-1"><dt class="text-slate-500">Comptes bancaires</dt><dd class="font-medium text-slate-700">{{ entreprise.nb_comptes_bancaires }}</dd></div>
        </dl>
    </div>
</div>

<div class="mt-8">
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-slate-800 flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            Utilisateurs ({{ users|length }})
        </h3>
        <a href="/users/create" class="inline-flex items-center gap-1.5 text-sm text-indigo-600 hover:text-indigo-800 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter
        </a>
    </div>
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wider">
                <tr>
                    <th class="px-6 py-3 text-left font-semibold">Nom</th>
                    <th class="px-6 py-3 text-left font-semibold">Email</th>
                    <th class="px-6 py-3 text-left font-semibold">Inscription</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for u in users %}
                <tr class="hover:bg-slate-50/50 transition">
                    <td class="px-6 py-3 font-medium text-slate-800">{{ u.prenom }} {{ u.nom }}</td>
                    <td class="px-6 py-3 text-slate-500">{{ u.email }}</td>
                    <td class="px-6 py-3 text-slate-500">{{ u.created_at|date('d/m/Y') }}</td>
                    <td class="px-6 py-3 text-right">
                        <a href="/users/{{ u.id }}" class="text-indigo-600 hover:text-indigo-800 font-medium">Voir</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="px-6 py-8 text-center text-slate-400">Aucun utilisateur pour cette entreprise.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
