{% extends 'layout/app.html.twig' %}

{% block title %}Entreprises - ComptaV2 Admin{% endblock %}
{% block page_title %}Entreprises{% endblock %}

{% set active_page = 'entreprises' %}

{% block content %}
<div class="mb-6">
    <a href="/entreprises/create" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2.5 rounded-lg hover:bg-indigo-700 active:bg-indigo-800 transition font-medium shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nouvelle entreprise
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wider">
            <tr>
                <th class="px-6 py-3.5 text-left font-semibold">Raison sociale</th>
                <th class="px-6 py-3.5 text-left font-semibold">SIRET</th>
                <th class="px-6 py-3.5 text-left font-semibold">Ville</th>
                <th class="px-6 py-3.5 text-center font-semibold">Users</th>
                <th class="px-6 py-3.5 text-center font-semibold">Factures</th>
                <th class="px-6 py-3.5 text-right font-semibold">CA</th>
                <th class="px-6 py-3.5 text-center font-semibold">Statut</th>
                <th class="px-6 py-3.5"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for e in entreprises %}
            <tr class="hover:bg-slate-50/50 transition">
                <td class="px-6 py-4 font-medium text-slate-800">{{ e.raison_sociale }}</td>
                <td class="px-6 py-4 text-slate-500 font-mono text-xs">{{ e.siret }}</td>
                <td class="px-6 py-4 text-slate-500">{{ e.ville }}</td>
                <td class="px-6 py-4 text-center text-slate-600">{{ e.nb_users }}</td>
                <td class="px-6 py-4 text-center text-slate-600">{{ e.nb_factures }}</td>
                <td class="px-6 py-4 text-right font-medium text-slate-700">{{ e.ca_total|number_format(2, ',', ' ') }} &euro;</td>
                <td class="px-6 py-4 text-center">
                    {% if e.active %}
                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200">Active</span>
                    {% else %}
                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-red-50 text-red-700 ring-1 ring-red-200">Suspendue</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 text-right">
                    <a href="/entreprises/{{ e.id }}" class="text-indigo-600 hover:text-indigo-800 font-medium">Voir</a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="8" class="px-6 py-12 text-center text-slate-400">Aucune entreprise enregistrée.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
