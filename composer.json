{
    "name": "comptav2/comptav2",
    "description": "Webapp de comptabilité pour freelance",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "twig/twig": "^3.0",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-intl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
